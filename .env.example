# SEO Indexing Control (set to 'true' to allow search engine crawling)
PUBLIC_ALLOW_INDEXING=false

# Google Analytics 4 Measurement ID (leave empty to disable)
PUBLIC_GA_MEASUREMENT_ID=

# Base URL of the Vocab Mine app — pricing buttons, blog deep-links, etc.
# all build off this. No trailing slash. Defaults to the dev domain when unset.
PUBLIC_APP_URL=https://word-master-app.dev.nhatbui.link

# Support email shown in footer / contact links (optional override)
PUBLIC_SUPPORT_EMAIL=
