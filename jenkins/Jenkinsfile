pipeline {
    agent any

    tools {
        nodejs 'node-22'
    }

    parameters {
        choice(
            name: 'ENVIRONMENT',
            choices: ['dev', 'staging', 'prod'],
            description: 'Environment to deploy to'
        )
        string(
            name: 'PROJECT_NAME',
            defaultValue: 'word-master-landing',
            description: 'Project name (must match CDK configuration)'
        )
        // Build-time env vars. Previously fetched from SSM Parameter Store;
        // now sourced directly from Jenkins so we don't depend on AWS
        // CodePipeline / SSM round-trips. Set the actual values per-job
        // (job config persists them).
        string(
            name: 'APP_URL',
            defaultValue: 'https://word-master-app.dev.nhatbui.link',
            description: 'Vocab Mine app base URL — pricing buttons + blog deep-links build off this. No trailing slash.'
        )
        string(
            name: 'SUPPORT_EMAIL',
            defaultValue: '',
            description: 'Support email shown in footer / contact links (optional)'
        )
        string(
            name: 'GA_MEASUREMENT_ID',
            defaultValue: '',
            description: 'Google Analytics 4 Measurement ID (leave blank to disable)'
        )
        booleanParam(
            name: 'ALLOW_INDEXING',
            defaultValue: false,
            description: 'Allow search engine crawling (true for prod, false for dev)'
        )
        // Blog data plane — Vikunja #76. Landing sources blog articles
        // from the backend's PUBLIC blog API at build time (not local .md
        // files). The public endpoints (GET /blog/articles[/:id]) only
        // ever expose published articles, so the build needs just the
        // base URL of the target env's backend — no auth token.
        string(
            name: 'BLOG_API_BASE_URL',
            defaultValue: 'http://192.168.1.9:8020',
            description: 'Backend API base URL used to fetch published articles at build time. Dev: Dell (http://192.168.1.9:8020). Staging: https://staging-be-5ae3fa73.vocabmine.com.'
        )
        // Vikunja #114 — runtime URL the browser hits for /blog/search.
        // Distinct from BLOG_API_BASE_URL because the build host can reach
        // the backend via a LAN shortcut (e.g. 192.168.1.9:8020) but the
        // browser must use a publicly resolvable hostname.
        string(
            name: 'PUBLIC_BLOG_API_BASE_URL',
            defaultValue: 'http://api.word-master.local',
            description: 'Backend API base URL the BROWSER will call at runtime (live blog search). Dev: http://api.word-master.local. Staging: https://staging-be-5ae3fa73.vocabmine.com. Prod: https://api.vocabmine.com.'
        )
    }

    environment {
        // AWS Region - update this to match your AWS setup
        AWS_REGION = credentials('aws-region')
        AWS_ACCOUNT_ID = credentials('aws-account-id')

        // Stack name pattern for CloudFormation exports
        STACK_NAME_PREFIX = getStackNamePrefix(params.PROJECT_NAME)

        // Add common binary paths (AWS CLI, etc.)
        PATH = "/usr/local/bin:/usr/bin:/usr/local/aws-cli/v2/current/bin:${env.PATH}"
    }

    stages {
        stage('Checkout') {
            steps {
                echo "Checking out code..."
                checkout scm

                script {
                    echo "================================"
                    echo "Build Information"
                    echo "================================"
                    echo "Environment: ${params.ENVIRONMENT}"
                    echo "Build Number: ${env.BUILD_NUMBER}"
                    echo "Build ID: ${env.BUILD_ID}"
                    echo "================================"
                }
            }
        }

        stage('Resolve Region') {
            steps {
                script {
                    // Staging + prod static-site stacks (S3 + CloudFront + ACM)
                    // are in us-east-1 because CloudFront requires its certs
                    // there; dev still uses the default aws-region credential.
                    env.DEPLOY_REGION = (params.ENVIRONMENT == 'staging' || params.ENVIRONMENT == 'prod') ? 'us-east-1' : env.AWS_REGION
                    echo "Deploy region: ${env.DEPLOY_REGION}"
                }
            }
        }

        stage('Install Dependencies') {
            steps {
                echo "Installing dependencies..."
                sh 'npm ci'
            }
        }

        stage('Create Environment File') {
            steps {
                script {
                    echo "Writing build-time .env from Jenkins parameters..."
                    sh """
                        echo "PUBLIC_ALLOW_INDEXING=${params.ALLOW_INDEXING}" > .env
                        if [ -n "${params.SUPPORT_EMAIL}" ]; then
                            echo "PUBLIC_SUPPORT_EMAIL=${params.SUPPORT_EMAIL}" >> .env
                        fi
                        if [ -n "${params.GA_MEASUREMENT_ID}" ] && [ "${params.GA_MEASUREMENT_ID}" != "none" ]; then
                            echo "PUBLIC_GA_MEASUREMENT_ID=${params.GA_MEASUREMENT_ID}" >> .env
                        fi
                        if [ -n "${params.APP_URL}" ]; then
                            echo "PUBLIC_APP_URL=${params.APP_URL}" >> .env
                        fi
                        if [ -n "${params.PUBLIC_BLOG_API_BASE_URL}" ]; then
                            echo "PUBLIC_BLOG_API_BASE_URL=${params.PUBLIC_BLOG_API_BASE_URL}" >> .env
                        fi
                        echo ".env file created"
                        cat .env
                    """
                }
            }
        }

        stage('Build') {
            steps {
                echo "Building Astro site..."
                // Articles are fetched at build time from the backend's
                // PUBLIC blog API — no auth token required. Vikunja #76.
                sh "BLOG_API_BASE_URL='${params.BLOG_API_BASE_URL}' npm run build"
            }
        }

        stage('Verify AWS CLI') {
            steps {
                script {
                    echo "Verifying AWS CLI setup..."
                    sh """
                        which aws || echo "AWS CLI not found in PATH"
                        aws --version || echo "AWS CLI not available"
                    """
                }
            }
        }

        stage('Fetch Deployment Targets') {
            steps {
                script {
                    echo "Fetching S3 bucket and CloudFront distribution information..."

                    withAWS(credentials: 'aws-credentials', region: env.DEPLOY_REGION) {
                        // Fetch S3 bucket name from CloudFormation exports
                        def bucketName = sh(
                            script: """
                                aws cloudformation list-exports \
                                    --region ${env.DEPLOY_REGION} \
                                    --query "Exports[?Name=='${STACK_NAME_PREFIX}-${params.ENVIRONMENT}-BucketName'].Value" \
                                    --output text
                            """,
                            returnStdout: true
                        ).trim()

                        // Fetch CloudFront distribution ID from CloudFormation exports
                        def distributionId = sh(
                            script: """
                                aws cloudformation list-exports \
                                    --region ${env.DEPLOY_REGION} \
                                    --query "Exports[?Name=='${STACK_NAME_PREFIX}-${params.ENVIRONMENT}-DistributionId'].Value" \
                                    --output text
                            """,
                            returnStdout: true
                        ).trim()

                        if (!bucketName || !distributionId) {
                            error("Failed to fetch deployment targets. Ensure CDK stacks are deployed.")
                        }

                        env.S3_BUCKET = bucketName
                        env.DISTRIBUTION_ID = distributionId

                        echo "Deployment targets:"
                        echo "   S3 Bucket: ${env.S3_BUCKET}"
                        echo "   CloudFront Distribution: ${env.DISTRIBUTION_ID}"
                    }
                }
            }
        }

        stage('Deploy to S3') {
            steps {
                script {
                    echo "Deploying static files to S3..."

                    withAWS(credentials: 'aws-credentials', region: env.DEPLOY_REGION) {
                        // Pass 1: HTML files — short cache (5 min) so a
                        // redeploy is visible immediately.
                        sh """
                            aws s3 sync dist/ s3://${env.S3_BUCKET} \
                                --exclude "*" \
                                --include "*.html" \
                                --cache-control "public,max-age=300" \
                                --region ${env.DEPLOY_REGION}
                        """

                        // Pass 2: Astro hashed bundles under _astro/* —
                        // filename changes per build → safe to cache
                        // forever.
                        sh """
                            aws s3 sync dist/ s3://${env.S3_BUCKET} \
                                --exclude "*" \
                                --include "_astro/*" \
                                --cache-control "public,max-age=31536000,immutable" \
                                --region ${env.DEPLOY_REGION}
                        """

                        // Pass 3: Everything else (favicon, logo,
                        // og-image, robots.txt, etc.) — stable filename
                        // so any redesign would stay cached for users.
                        // Cap at 1 day.
                        sh """
                            aws s3 sync dist/ s3://${env.S3_BUCKET} \
                                --exclude "*.html" \
                                --exclude "_astro/*" \
                                --cache-control "public,max-age=86400" \
                                --region ${env.DEPLOY_REGION}
                        """

                        // Pass 4: Delete files from S3 that no longer exist in dist/
                        sh """
                            aws s3 sync dist/ s3://${env.S3_BUCKET} \
                                --delete \
                                --region ${env.DEPLOY_REGION}
                        """

                        echo "Deployed to S3 successfully"
                    }
                }
            }
        }

        stage('Invalidate CloudFront Cache') {
            steps {
                script {
                    echo "Invalidating CloudFront cache..."

                    withAWS(credentials: 'aws-credentials', region: env.DEPLOY_REGION) {
                        def invalidationId = sh(
                            script: """
                                aws cloudfront create-invalidation \
                                    --distribution-id ${env.DISTRIBUTION_ID} \
                                    --paths "/*" \
                                    --query 'Invalidation.Id' \
                                    --output text
                            """,
                            returnStdout: true
                        ).trim()

                        echo "CloudFront invalidation created: ${invalidationId}"
                        echo "   It may take a few minutes for the cache to be fully invalidated."
                    }
                }
            }
        }
    }

    post {
        success {
            echo """
================================
  Deployment Successful!
  Environment: ${params.ENVIRONMENT}
  S3 Bucket: ${env.S3_BUCKET ?: 'N/A'}
  CloudFront: ${env.DISTRIBUTION_ID ?: 'N/A'}
================================
            """
        }
        failure {
            echo """
================================
  Deployment Failed
  Please check the logs above for error details.
================================
            """
        }
        always {
            cleanWs(
                deleteDirs: true,
                patterns: [
                    [pattern: '.env', type: 'INCLUDE']
                ]
            )
        }
    }
}

// Helper function to convert project name to PascalCase for CloudFormation export names
def getStackNamePrefix(String projectName) {
    return projectName.split('-')
        .collect { it.capitalize() }
        .join('')
}
