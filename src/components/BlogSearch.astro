---
/**
 * Blog search box (Vikunja #121, #122).
 *
 * Plain GET form that submits to /blog/search?q=…. NO autocomplete
 * dropdown, NO per-keystroke fetch — that proved distracting per user
 * feedback. Pressing Enter (or clicking the magnifier) navigates to the
 * dedicated results page, which makes the URL bookmarkable and gives
 * back/forward something to land on.
 *
 * The clear (X) button is a 44×44 px tap target per WCAG 2.5.5; the
 * visible icon stays small inside.
 */
---

<form
  class="blog-search"
  action="/blog/search"
  method="get"
  role="search"
  aria-label="Search the blog"
>
  <label class="blog-search__label" for="blog-search-input">
    <span class="blog-search__sr-only">Search the blog</span>
    <input
      id="blog-search-input"
      class="blog-search__input"
      type="search"
      name="q"
      placeholder="Search the blog…"
      autocomplete="off"
      autocapitalize="off"
      autocorrect="off"
      spellcheck="false"
      maxlength="200"
    />
    <button
      type="button"
      class="blog-search__clear"
      aria-label="Clear search"
      data-blog-search-clear
      hidden
    >
      <svg
        class="blog-search__clear-icon"
        viewBox="0 0 20 20"
        width="14"
        height="14"
        aria-hidden="true"
        focusable="false"
      >
        <path
          d="M5 5l10 10M15 5L5 15"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        />
      </svg>
    </button>
    <button type="submit" class="blog-search__submit" aria-label="Search">
      <svg
        class="blog-search__submit-icon"
        viewBox="0 0 24 24"
        width="18"
        height="18"
        aria-hidden="true"
        focusable="false"
      >
        <circle cx="11" cy="11" r="7" fill="none" stroke="currentColor" stroke-width="2" />
        <path d="M16.5 16.5L21 21" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      </svg>
    </button>
  </label>
</form>

<script>
  /**
   * Show/hide the clear button based on whether the input has content.
   * Clicking it empties the input and refocuses (so users can keep
   * typing without re-clicking). Submission is handled by the browser
   * (the form is a plain GET) — no fetch, no preventDefault.
   */
  const input = document.getElementById('blog-search-input') as HTMLInputElement | null;
  const clearBtn = document.querySelector<HTMLButtonElement>('[data-blog-search-clear]');
  const form = input?.closest('form');

  if (input && clearBtn) {
    function syncClearVisibility(): void {
      clearBtn!.hidden = input!.value.length === 0;
    }

    input.addEventListener('input', syncClearVisibility);
    clearBtn.addEventListener('click', () => {
      input.value = '';
      syncClearVisibility();
      input.focus();
    });

    syncClearVisibility();
  }

  // When the user submits with an empty query (cleared the input then
  // hit Enter / clicked the magnifier), send them to /blog/ — they
  // clearly want "all posts", not the empty-state search page.
  if (form && input) {
    form.addEventListener('submit', (e) => {
      if (input.value.trim().length === 0) {
        e.preventDefault();
        window.location.assign('/blog/');
      }
    });
  }
</script>

<style>
  .blog-search {
    margin: 24px auto 32px;
    max-width: 640px;
  }

  .blog-search__sr-only {
    border: 0;
    clip: rect(0 0 0 0);
    height: 1px;
    margin: -1px;
    overflow: hidden;
    padding: 0;
    position: absolute;
    white-space: nowrap;
    width: 1px;
  }

  .blog-search__label {
    align-items: center;
    background: var(--color-bg-alt, #f5f7fb);
    border: 1px solid var(--color-border, #d1d5db);
    border-radius: 999px;
    display: flex;
    gap: 4px;
    padding: 4px 4px 4px 18px;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .blog-search__label:focus-within {
    border-color: var(--color-primary, #2563eb);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.18);
  }

  .blog-search__input {
    background: transparent;
    border: 0;
    color: var(--color-text);
    flex: 1;
    font-size: 1rem;
    min-width: 0;
    outline: none;
    padding: 10px 0;
  }
  .blog-search__input::placeholder {
    color: var(--color-text-secondary);
    opacity: 0.7;
  }
  /* Hide the WebKit/Edge built-in [x] clear button — we ship our own
     with a proper tap target. */
  .blog-search__input::-webkit-search-cancel-button,
  .blog-search__input::-webkit-search-decoration {
    -webkit-appearance: none;
    appearance: none;
  }

  /* 44×44 tap target per WCAG 2.5.5. Visible icon is tiny; the button
     itself is fully clickable. */
  .blog-search__clear,
  .blog-search__submit {
    align-items: center;
    background: transparent;
    border: 0;
    border-radius: 999px;
    color: var(--color-text-secondary);
    cursor: pointer;
    display: inline-flex;
    flex: 0 0 auto;
    height: 44px;
    justify-content: center;
    padding: 0;
    width: 44px;
  }
  .blog-search__clear:hover,
  .blog-search__clear:focus-visible {
    background: rgba(0, 0, 0, 0.06);
    color: var(--color-text);
    outline: none;
  }
  .blog-search__submit {
    color: var(--color-primary, #2563eb);
  }
  .blog-search__submit:hover,
  .blog-search__submit:focus-visible {
    background: rgba(37, 99, 235, 0.12);
    outline: none;
  }
</style>
