---
/**
 * Editorial callout block — three variants (info / warning / tip).
 * Inserted inline in article bodies via the admin TipTap editor's
 * paired-marker pattern; Vikunja #68.
 */
interface Props {
  /** HTML already produced by `marked.parse()` from the inner markdown. */
  html: string;
  variant: "info" | "warning" | "tip";
  /** Newspaper-style float position. Vikunja #123. Default `full`
   *  preserves the historic full-width block; `left`/`right` floats the
   *  callout at ~40% width so adjacent paragraphs wrap around it.
   *  Mobile (≤768px) drops the float and stacks. */
  align?: "full" | "left" | "right";
}

const { html, variant, align = "full" } = Astro.props;
const labels: Record<Props["variant"], string> = {
  info: "Note",
  tip: "Tip",
  warning: "Warning",
};
---

<aside class={`callout float-${align}`} data-variant={variant} data-align={align} role="note">
  <div class="callout__label">{labels[variant]}</div>
  <div class="callout__body" set:html={html} />
</aside>

<style>
  .callout {
    border-left: 4px solid;
    border-radius: 4px;
    margin: 24px 0;
    padding: 16px 20px;
  }
  .callout__label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    margin-bottom: 8px;
    text-transform: uppercase;
  }
  .callout__body :global(p) {
    color: inherit;
    line-height: 1.6;
    margin: 0 0 8px 0;
  }
  .callout__body :global(p:last-child) {
    margin-bottom: 0;
  }
  .callout__body :global(a) {
    color: inherit;
    text-decoration: underline;
  }
  .callout__body :global(code) {
    background: rgba(0, 0, 0, 0.06);
    border-radius: 3px;
    font-family: monospace;
    font-size: 0.92em;
    padding: 1px 5px;
  }

  /* Variants — light-mode default with stable dark-mode hooks. */
  .callout[data-variant="info"] {
    background: #eef4fb;
    border-color: #3b82f6;
    color: #1e3a8a;
  }
  .callout[data-variant="warning"] {
    background: #fff7e6;
    border-color: #f59e0b;
    color: #78350f;
  }
  .callout[data-variant="tip"] {
    background: #ecfdf5;
    border-color: #10b981;
    color: #065f46;
  }

  /* Dark mode: BlogPostLayout doesn't currently toggle theme, but the
     base layout's `[data-theme="dark"]` hook is already wired site-wide.
     Keep the variants legible if a future dark-mode pass enables it. */
  :global([data-theme="dark"]) .callout[data-variant="info"] {
    background: #1e293b;
    color: #cbd5ff;
  }
  :global([data-theme="dark"]) .callout[data-variant="warning"] {
    background: #422006;
    color: #fde68a;
  }
  :global([data-theme="dark"]) .callout[data-variant="tip"] {
    background: #052e1f;
    color: #a7f3d0;
  }

  /* Newspaper-style float layout (Vikunja #123). Same .float-{align}
     pattern used by CollectionCta and inline images, so any future
     floatable component can drop in without re-declaring the rules. */
  .callout.float-full {
    clear: both;
  }
  .callout.float-left {
    clear: left;
    float: left;
    margin: 0.5em 1.5em 0.5em 0;
    width: 40%;
  }
  .callout.float-right {
    clear: right;
    float: right;
    margin: 0.5em 0 0.5em 1.5em;
    width: 40%;
  }
  @media (max-width: 768px) {
    .callout.float-left,
    .callout.float-right {
      float: none;
      margin: 24px 0;
      width: 100%;
    }
  }
</style>
