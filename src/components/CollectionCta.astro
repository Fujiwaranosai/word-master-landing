---
import { APP_URL } from '../consts';

/**
 * Inline collection pull-out — appears in the middle of an article when
 * the article has a bound vocabulary collection. Styled as a magazine
 * editorial highlight (color-coded left bar, tinted background, eyebrow
 * label) so readers immediately notice it as the actionable in-article
 * element. Vikunja #116, #118.
 */
interface Props {
  // Stable, environment-portable identifier set by an admin in the
  // Vocab Mine admin panel (e.g., "sherlock-holmes-chapter-1"). The
  // app's /collections/by-slug/:slug route resolves this to the
  // current-environment collection ID, so the same .md file works in
  // dev and prod without per-deploy edits.
  collectionSlug: string;
  words?: string[];
  title?: string;
}

const { collectionSlug, words, title = 'Learn these words' } = Astro.props;
const ctaUrl = `${APP_URL}/collections/by-slug/${collectionSlug}`;
const wordCount = words?.length ?? 0;
---

<aside class="collection-cta">
  <div class="collection-cta__eyebrow">From this article</div>
  <h3 class="collection-cta__title">{title}</h3>
  {words && words.length > 0 && (
    <div class="collection-cta__words">
      {words.map((word) => (
        <span class="collection-cta__word">{word}</span>
      ))}
    </div>
  )}
  <a
    href={ctaUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="collection-cta__btn"
    data-ga-cta="add_to_vocabulary"
    data-ga-location="blog_collection_cta"
  >
    Master {wordCount > 0 ? `${wordCount} ${wordCount === 1 ? 'word' : 'words'}` : 'this vocabulary'} →
  </a>
</aside>

<style>
  /* Magazine pull-out highlight — the kind of attention-grabbing box a
     news article would use to anchor a key sidebar. Bolder left accent
     and a subtle gradient give it more presence than the in-body
     callouts (which are notes); this one is the actionable element. */
  .collection-cta {
    background: linear-gradient(135deg, #eff6ff 0%, #f8fbff 100%);
    border-left: 8px solid #2563eb;
    border-radius: 6px;
    box-shadow: 0 6px 24px -8px rgba(37, 99, 235, 0.18);
    margin: 56px 0;
    padding: 32px 36px;
    position: relative;
  }

  .collection-cta__eyebrow {
    color: #2563eb;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    margin-bottom: 10px;
    text-transform: uppercase;
  }

  .collection-cta__title {
    color: #0f172a;
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 20px 0;
  }

  .collection-cta__words {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 26px;
  }

  .collection-cta__word {
    background: #ffffff;
    border: 1px solid #c7d8ee;
    border-radius: 100px;
    color: #1e3a8a;
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 600;
    line-height: 1.4;
    padding: 6px 14px;
  }

  .collection-cta__btn {
    align-items: center;
    background: #2563eb;
    border: 0;
    border-radius: 8px;
    box-shadow: 0 2px 6px rgba(37, 99, 235, 0.25);
    color: #ffffff;
    display: inline-flex;
    font-size: 0.95rem;
    font-weight: 600;
    gap: 4px;
    padding: 12px 22px;
    text-decoration: none;
    transition: transform 0.12s ease, box-shadow 0.12s ease, background 0.12s ease;
  }
  .collection-cta__btn:hover {
    background: #1d4ed8;
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.32);
    transform: translateY(-1px);
  }

  /* Dark-mode hook — the rest of the landing uses `[data-theme="dark"]`. */
  :global([data-theme="dark"]) .collection-cta {
    background: linear-gradient(135deg, #1e3a8a 0%, #1e293b 100%);
    box-shadow: 0 6px 24px -8px rgba(59, 130, 246, 0.3);
  }
  :global([data-theme="dark"]) .collection-cta__eyebrow {
    color: #93c5fd;
  }
  :global([data-theme="dark"]) .collection-cta__title {
    color: #e2e8f0;
  }
  :global([data-theme="dark"]) .collection-cta__word {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.16);
    color: #cbd5ff;
  }

  @media (max-width: 600px) {
    .collection-cta {
      border-left-width: 6px;
      margin: 40px 0;
      padding: 24px 22px;
    }
    .collection-cta__title {
      font-size: 1.25rem;
    }
    .collection-cta__btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
