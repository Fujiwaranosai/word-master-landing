---
import { SITE_NAME, APP_URL } from '../consts';

interface Props {
  currentPage?: string;
}

const { currentPage = '' } = Astro.props;

const isHome = currentPage === 'home';
const featuresHref = isHome ? '#features' : '/#features';
const howItWorksHref = isHome ? '#how-it-works' : '/#how-it-works';
const LOGIN_URL = `${APP_URL}/login`;
---

<nav class="nav">
  <div class="container nav__inner">
    <a href="/" class="nav__logo" aria-label={`${SITE_NAME} home`}>
      <!-- Brand mark inlined so it inherits currentColor and tracks the nav text colour. Source: web app public/logo-mark.svg -->
      <svg class="nav__logo-mark" viewBox="0 0 380 294" width="30" height="23" fill="currentColor" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
        <path d="M339.64 78.7813L294.741 164.165L284.177 198.494L233.469 227.982L197.55 273.314C197.55 273.314 207.058 182.209 208.114 177.808C209.171 173.407 215.509 145.239 227.658 133.796C239.807 122.353 263.049 106.069 268.331 103.428C273.613 100.787 300.552 88.464 300.552 88.464L339.64 78.7813Z"/>
        <path d="M43.3102 78.8801L88.2939 164.232L98.8926 198.554L149.631 228.007L185.595 273.314C185.595 273.314 175.996 182.216 174.935 177.816C173.874 173.415 167.507 145.252 155.347 133.817C143.186 122.383 119.929 106.114 114.644 103.477C109.359 100.84 82.4078 88.5356 82.4078 88.5356L43.3102 78.8801Z"/>
        <path d="M28.5211 122.793L44.8958 128.955L82.9273 215.219C82.9273 215.219 111.451 221.38 134.692 238.105C157.934 254.829 167.97 271.114 167.97 271.114L70.7783 230.183L28.5211 122.793Z"/>
        <path d="M0 153.602L16.3747 150.521L54.4061 246.027C54.4061 246.027 100.889 253.509 135.751 267.593C170.613 281.677 181.706 293.56 181.706 293.56L42.2572 260.991L0 153.602Z"/>
        <path d="M379.255 154.042L362.88 150.961L324.849 246.467C324.849 246.467 278.366 253.949 243.504 268.033C208.641 282.117 197.549 294 197.549 294L336.998 261.431L379.255 154.042Z"/>
        <path d="M358.13 118.392L341.755 124.554L303.724 210.817C303.724 210.817 275.2 216.979 251.959 233.704C228.717 250.428 218.681 266.713 218.681 266.713L315.873 225.781L358.13 118.392Z"/>
        <path d="M193.329 0L206.006 38.2904L244.037 48.4132L203.365 63.3772L193.329 99.0269L179.595 60.7365L138.922 48.4132L177.482 38.2904L193.329 0Z"/>
      </svg>
      <span class="nav__logo-text">{SITE_NAME}</span>
    </a>
    <div class="nav__links" id="navLinks">
      <a href={howItWorksHref} class="nav__link">How it Works</a>
      <a href={featuresHref} class="nav__link">Features</a>
      <a href="/pricing/" class="nav__link">Pricing</a>
      <a href="/blog/" class="nav__link">Blog</a>
      <button
        type="button"
        class="theme-toggle"
        id="themeToggle"
        aria-label="Toggle dark mode"
        aria-pressed="false"
      >
        <svg class="theme-toggle__icon theme-toggle__icon--moon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
        <svg class="theme-toggle__icon theme-toggle__icon--sun" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2" />
          <path d="M12 20v2" />
          <path d="M4.93 4.93l1.41 1.41" />
          <path d="M17.66 17.66l1.41 1.41" />
          <path d="M2 12h2" />
          <path d="M20 12h2" />
          <path d="M4.93 19.07l1.41-1.41" />
          <path d="M17.66 6.34l1.41-1.41" />
        </svg>
      </button>
      <a href={LOGIN_URL} class="nav__login">Login</a>
      <a href={APP_URL} class="btn btn--primary nav__cta" data-ga-cta="get_started_free" data-ga-location="nav">Get started</a>
    </div>
    <button class="nav__toggle" id="navToggle" aria-label="Toggle navigation">
      <span class="nav__toggle-bar"></span>
      <span class="nav__toggle-bar"></span>
      <span class="nav__toggle-bar"></span>
    </button>
  </div>
</nav>

<style>
  /* The nav is a permanent deep-blue band in both themes, matching the
     design's always-blue top bar (#0c1436). Text + mark are white. */
  .nav__logo-mark {
    display: block;
    color: #ffffff;
    flex-shrink: 0;
  }

  .nav__logo-text {
    color: #ffffff;
  }

  .nav__login {
    display: inline-flex;
    align-items: center;
    padding: 0 18px;
    height: 38px;
    border: 1px solid #3c425d;
    border-radius: 10px;
    color: #ffffff;
    font-weight: 500;
    text-decoration: none;
    transition: border-color 0.2s, background 0.2s;
  }

  .nav__login:hover {
    border-color: #60a5fa;
    background: rgba(96, 165, 250, 0.08);
  }

  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    padding: 0;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 999px;
    background: transparent;
    color: rgba(255, 255, 255, 0.75);
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }

  .theme-toggle:hover {
    color: #ffffff;
    border-color: rgba(255, 255, 255, 0.5);
  }

  .theme-toggle:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .theme-toggle__icon {
    display: block;
  }

  /* Show moon when in light mode (click → dark);
     show sun when in dark mode (click → light). */
  .theme-toggle__icon--sun {
    display: none;
  }

  :root[data-theme="dark"] .theme-toggle__icon--moon {
    display: none;
  }

  :root[data-theme="dark"] .theme-toggle__icon--sun {
    display: block;
  }
</style>

<script>
  // --- Theme Toggle ---
  // The no-flash inline script in BaseLayout already sets the initial
  // [data-theme] before paint. This handler only manages user toggling
  // and persistence.
  const themeToggle = document.getElementById('themeToggle');

  function syncTogglePressed() {
    if (!themeToggle) return;
    const current = document.documentElement.getAttribute('data-theme') || 'light';
    themeToggle.setAttribute('aria-pressed', current === 'dark' ? 'true' : 'false');
  }

  syncTogglePressed();

  if (themeToggle) {
    themeToggle.addEventListener('click', function () {
      const current = document.documentElement.getAttribute('data-theme') || 'light';
      const next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      try {
        localStorage.setItem('vocabmine-theme', next);
      } catch (_) {
        /* storage blocked — toggle still works for the session */
      }
      syncTogglePressed();
    });
  }
</script>
