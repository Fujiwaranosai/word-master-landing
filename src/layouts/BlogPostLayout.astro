---
import BaseLayout from './BaseLayout.astro';
import CollectionCta from '../components/CollectionCta.astro';
import { SITE_NAME, SITE_URL } from '../consts';

interface Props {
  title: string;
  pubDate: Date;
  description: string;
  author: string;
  tags?: string[];
  collectionSlug?: string;
  collectionWords?: string[];
  /** Slug derived from the file name; used to build the article URL. */
  slug?: string;
}

const { title, pubDate, description, author, tags = [], collectionSlug, collectionWords, slug } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Article schema: each blog post emits its own JSON-LD on top of the
// site-wide WebSite + Organization graphs from BaseLayout. The
// `mainEntityOfPage` ties the article to its canonical URL.
const articleUrl = slug ? `${SITE_URL}/blog/${slug}/` : undefined;
const articleSchema = {
  '@type': 'Article',
  '@id': articleUrl ? `${articleUrl}#article` : undefined,
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  author: { '@type': 'Organization', name: author, url: SITE_URL },
  publisher: { '@id': `${SITE_URL}/#organization` },
  mainEntityOfPage: articleUrl,
  keywords: tags.join(', '),
  image: `${SITE_URL}/og-image.png`,
};
---

<BaseLayout
  title={`${title} — ${SITE_NAME} Blog`}
  description={description}
  ogTitle={title}
  ogDescription={description}
  ogType="article"
  twitterCard="summary_large_image"
  canonicalPath={slug ? `/blog/${slug}/` : undefined}
  currentPage="blog"
  pageSchema={articleSchema}
>
  <article class="blog-post">
    <div class="container">
      <div class="blog-post__content">
        <a href="/blog/" class="blog-post__back">&larr; Back to Blog</a>
        <h1>{title}</h1>
        <div class="blog-post__meta">
          <time datetime={pubDate.toISOString()}>{formattedDate}</time>
          <span class="blog-post__author">by {author}</span>
        </div>
        {tags.length > 0 && (
          <div class="blog-post__tags">
            {tags.map((tag) => (
              <span class="blog-post__tag">{tag}</span>
            ))}
          </div>
        )}
        <div class="blog-post__body">
          <slot />
        </div>
        {collectionSlug && (
          <CollectionCta collectionSlug={collectionSlug} words={collectionWords} />
        )}
      </div>
    </div>
  </article>
</BaseLayout>
