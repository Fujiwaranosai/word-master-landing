---
import BaseLayout from './BaseLayout.astro';
import { ARTICLE_TOPIC_LABELS, type ArticleTopic } from '../lib/blog-articles';
import { SITE_NAME, SITE_URL } from '../consts';

interface SourceRef {
  attribution: string;
  license?: string;
  url: string;
}

interface Props {
  title: string;
  pubDate: Date;
  description: string;
  /** Kept for backwards compatibility — every post is published under
   *  the site brand, so we no longer render a per-article byline or
   *  feed `author` into JSON-LD. The prop stays in the signature so
   *  the existing caller in pages/blog/[...slug].astro doesn't need a
   *  matching edit and a future per-author scheme can re-use the
   *  field. */
  author?: string;
  tags?: string[];
  /** Editorial topic — rendered as a chip next to the title; the
   *  per-topic accent color helps readers instantly tell a vocab
   *  deep-dive from an announcement. Vikunja #113. */
  topic?: ArticleTopic;
  /** Cover image — rendered at the top of the article AND used as the OG
   *  image for SERP / social. Falls back to the site-wide og-image when
   *  the article has no cover (announcement-style posts often skip it). */
  heroImageUrl?: string | null;
  heroImageAlt?: string | null;
  /** Sources block at the bottom of the article — attribution + licence
   *  for any external material the body draws on (Vikunja #75 originally
   *  added this as part of the editorial playbook). */
  sources?: SourceRef[];
  /** Slug derived from the article row; used to build the article URL. */
  slug?: string;
  /** When set, the article's updatedAt — emitted as dateModified on the
   *  JSON-LD so SERPs know how fresh the content is. */
  updatedAt?: Date;
}

const {
  title,
  pubDate,
  description,
  tags = [],
  topic,
  heroImageUrl,
  heroImageAlt,
  sources = [],
  slug,
  updatedAt,
} = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Per-article OG image: prefer the article's cover. Falls back to the
// site-wide og-image.png when the article has no cover (announcements,
// general posts, etc.). Vikunja #76 SEO checklist.
const ogImage = heroImageUrl || `${SITE_URL}/og-image.png`;

// Article schema: each blog post emits its own JSON-LD on top of the
// site-wide WebSite + Organization graphs from BaseLayout. The
// `mainEntityOfPage` ties the article to its canonical URL.
const articleUrl = slug ? `${SITE_URL}/blog/${slug}/` : undefined;
const articleSchema: Record<string, unknown> = {
  '@type': 'Article',
  '@id': articleUrl ? `${articleUrl}#article` : undefined,
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  // All articles are published under the site brand — every post is
  // authored in-house, so we credit the Organization rather than a
  // per-post user. Keeps structured data aligned with the publisher
  // identity instead of leaking an internal "admin" handle.
  author: { '@type': 'Organization', name: SITE_NAME, url: SITE_URL },
  publisher: { '@id': `${SITE_URL}/#organization` },
  mainEntityOfPage: articleUrl,
  keywords: tags.join(', '),
  image: ogImage,
};
if (updatedAt) {
  articleSchema.dateModified = updatedAt.toISOString();
}

// Breadcrumbs let Google show "vocabmine.com > Blog > Article Title"
// in SERP instead of the raw URL. Only emitted when we have a slug.
const breadcrumbSchema = articleUrl
  ? {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
        { '@type': 'ListItem', position: 2, name: 'Blog', item: `${SITE_URL}/blog/` },
        { '@type': 'ListItem', position: 3, name: title, item: articleUrl },
      ],
    }
  : undefined;

const pageSchema = breadcrumbSchema ? [articleSchema, breadcrumbSchema] : articleSchema;
---

<BaseLayout
  title={`${title} — ${SITE_NAME} Blog`}
  description={description}
  ogTitle={title}
  ogDescription={description}
  ogImage={ogImage}
  ogType="article"
  twitterCard="summary_large_image"
  canonicalPath={slug ? `/blog/${slug}/` : undefined}
  currentPage="blog"
  pageSchema={pageSchema}
>
  <article class="blog-post">
    <div class="container">
      {/* Breadcrumb sits ABOVE the article block so it reads as
          wayfinding, not metadata. Vikunja #117. */}
      <nav class="blog-post__breadcrumb" aria-label="Breadcrumb">
        <a href="/blog/">&larr; Blog</a>
      </nav>

      <div class="blog-post__content">
        {/* Header block: topic eyebrow → H1 → meta. Hero (if present)
            sits between eyebrow and H1 like an editorial cover; the
            eyebrow stays visible above it. */}
        <header class="blog-post__header">
          {topic && (
            <a href={`/blog/topic/${topic}/`} class="blog-post__topic" data-topic={topic}>
              {ARTICLE_TOPIC_LABELS[topic]}
            </a>
          )}

          {heroImageUrl && (
            <figure class="blog-post__hero">
              <img
                src={heroImageUrl}
                alt={heroImageAlt ?? ''}
                loading="eager"
                width="1200"
                height="630"
              />
              {heroImageAlt && (
                <figcaption class="blog-post__hero-caption">{heroImageAlt}</figcaption>
              )}
            </figure>
          )}

          <h1>{title}</h1>
          <div class="blog-post__meta">
            <time datetime={pubDate.toISOString()}>{formattedDate}</time>
          </div>
          {tags.length > 0 && (
            <div class="blog-post__tags">
              {tags.map((tag) => (
                <span class="blog-post__tag">{tag}</span>
              ))}
            </div>
          )}
        </header>
        <div class="blog-post__body">
          <slot />
        </div>

        {sources.length > 0 && (
          <aside class="blog-post__sources">
            <h2>Sources</h2>
            <ul>
              {sources.map((s) => (
                <li>
                  <a href={s.url} target="_blank" rel="noopener noreferrer">
                    {s.attribution || s.url}
                  </a>
                  {s.license && <span class="blog-post__source-license"> ({s.license})</span>}
                </li>
              ))}
            </ul>
          </aside>
        )}
      </div>
    </div>
  </article>
</BaseLayout>

<style is:global>
  /* Inline-image float layout (Vikunja #123). The image markup is raw
     HTML rendered via `marked.parse()` then `set:html`, so the rules
     can't live inside a scoped Astro <style> block — Astro's scoping
     prefix would only match nodes authored in this file, not the ones
     injected at runtime. `is:global` ships them as plain global CSS,
     applied site-wide via the `.blog-post__body` ancestor so they
     can't bleed into the rest of the marketing site. */
  .blog-post__body img.align-full {
    clear: both;
    display: block;
    margin: 1em auto;
    max-width: 100%;
  }
  .blog-post__body img.align-left {
    clear: left;
    float: left;
    height: auto;
    margin: 0.5em 1.5em 0.5em 0;
    max-width: 100%;
    width: 40%;
  }
  .blog-post__body img.align-right {
    clear: right;
    float: right;
    height: auto;
    margin: 0.5em 0 0.5em 1.5em;
    max-width: 100%;
    width: 40%;
  }
  @media (max-width: 768px) {
    .blog-post__body img.align-left,
    .blog-post__body img.align-right {
      float: none;
      margin: 1em 0;
      width: 100%;
    }
  }
  /* Clearfix on the body so the article footer (sources block) doesn't
     wrap into a still-floating image / callout / CTA above it. */
  .blog-post__body::after {
    clear: both;
    content: "";
    display: table;
  }
</style>
<style>
  .blog-post__hero {
    margin: 0 0 2rem 0;
  }
  .blog-post__hero img {
    border-radius: 8px;
    height: auto;
    max-width: 100%;
    width: 100%;
  }
  .blog-post__hero-caption {
    color: var(--color-text-secondary, #666);
    display: block;
    font-size: 0.875rem;
    margin-top: 0.5rem;
    text-align: center;
  }
  .blog-post__sources {
    border-top: 1px solid var(--color-border, #e5e5e5);
    margin-top: 3rem;
    padding-top: 2rem;
  }
  .blog-post__sources h2 {
    font-size: 1.125rem;
    margin: 0 0 1rem 0;
  }
  .blog-post__sources ul {
    list-style: none;
    padding: 0;
  }
  .blog-post__sources li {
    color: var(--color-text-secondary, #666);
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
  }
  .blog-post__source-license {
    color: var(--color-text-tertiary, #999);
  }
</style>
