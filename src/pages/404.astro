---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_NAME } from '../consts';
---

<BaseLayout
  title={`Page not found — ${SITE_NAME}`}
  description="The page you're looking for doesn't exist. Let's get you back to learning words."
  ogTitle="Page not found"
  ogDescription="The page you're looking for doesn't exist."
  ogType="website"
>
  <section class="not-found">
    <div class="container not-found__inner">
      <p class="not-found__code">404</p>
      <h1 class="not-found__title">Page not found</h1>
      <p class="not-found__lead">
        We couldn't find what you were looking for. The link may be broken,
        or the page may have moved.
      </p>
      <div class="not-found__actions">
        <a href="/" class="btn btn--primary btn--large">Go home</a>
        <a href="/blog/" class="btn btn--secondary btn--large">Read the blog</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    padding: 5rem 0 6rem;
    text-align: center;
  }
  .not-found__inner {
    max-width: 540px;
  }
  .not-found__code {
    font-size: clamp(4rem, 12vw, 7rem);
    font-weight: 700;
    line-height: 1;
    margin: 0 0 0.5rem;
    color: var(--color-text-muted, #6b7280);
    letter-spacing: -0.02em;
  }
  .not-found__title {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    margin: 0 0 1rem;
  }
  .not-found__lead {
    color: var(--color-text-muted, #4b5563);
    margin: 0 0 2rem;
  }
  .not-found__actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
