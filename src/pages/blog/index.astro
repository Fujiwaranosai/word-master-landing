---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogSearch from '../../components/BlogSearch.astro';
import { SITE_NAME } from '../../consts';
import {
  ARTICLE_TOPIC_LABELS,
  ARTICLE_TOPICS,
  fetchPublishedArticles,
  type ArticleTopic,
} from '../../lib/blog-articles';

/**
 * Blog index — now sourced from the admin API at build time (Vikunja #76)
 * instead of `getCollection('blog')` over local .md files. The article
 * row is the source of truth; the landing site is a stale-on-deploy
 * snapshot rebuilt by the landing Jenkins job after publishing.
 *
 * Pagination + topic filter chips: Vikunja #115. All articles are
 * rendered into the DOM at build time with `data-topic` markers; the
 * client island slices + filters in place rather than re-fetching.
 */
const posts = await fetchPublishedArticles();

// Per-topic counts for chip badges ("Vocabulary (12)" etc).
const topicCounts: Record<ArticleTopic, number> = {
  announcement: 0,
  'learning-science': 0,
  story: 0,
  vocabulary: 0,
  writing: 0,
};
for (const p of posts) {
  if (p.topic in topicCounts) topicCounts[p.topic]++;
}

const PAGE_SIZE_OPTIONS = [25, 50, 100] as const;
---

<BaseLayout
  title={`Blog — ${SITE_NAME}`}
  description={`Tips, strategies, and updates from the ${SITE_NAME} team to help you master vocabulary.`}
  canonicalPath="/blog/"
  currentPage="blog"
>
  <section class="blog-listing">
    <div class="container">
      <div class="blog-listing__header">
        <h1>Blog</h1>
        <p>Tips, strategies, and updates to help you master vocabulary like never before.</p>
      </div>

      <BlogSearch />

      <div class="blog-listing__filters">
        <div class="blog-listing__chips" role="group" aria-label="Filter by topic">
          <button class="blog-listing__chip" data-topic="all" type="button" aria-pressed="true">
            All <span class="blog-listing__chip-count">({posts.length})</span>
          </button>
          {ARTICLE_TOPICS.map((t) => (
            topicCounts[t] > 0 && (
              <button
                class="blog-listing__chip"
                data-topic={t}
                type="button"
                aria-pressed="false"
              >
                {ARTICLE_TOPIC_LABELS[t]} <span class="blog-listing__chip-count">({topicCounts[t]})</span>
              </button>
            )
          ))}
        </div>
        <label class="blog-listing__page-size">
          <span class="blog-listing__page-size-label">Show</span>
          <select id="blog-page-size" aria-label="Posts per page">
            {PAGE_SIZE_OPTIONS.map((n) => (
              <option value={n}>{n} per page</option>
            ))}
          </select>
        </label>
      </div>

      <div class="blog-listing__grid">
        {posts.map((post) => {
          const pubDate = post.publishedAt ? new Date(post.publishedAt) : new Date(post.createdAt);
          const formattedDate = pubDate.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          });
          return (
            <a
              href={`/blog/${post.slug}/`}
              class="blog-card fade-in"
              data-topic={post.topic}
            >
              <div class="blog-card__content">
                <span class="blog-card__topic" data-topic={post.topic}>
                  {ARTICLE_TOPIC_LABELS[post.topic]}
                </span>
                <time datetime={pubDate.toISOString()}>{formattedDate}</time>
                <h2>{post.title}</h2>
                <p>{post.description}</p>
              </div>
            </a>
          );
        })}
        {posts.length === 0 && (
          <p class="blog-listing__empty">No articles published yet. Check back soon.</p>
        )}
      </div>

      <nav class="blog-listing__pagination" aria-label="Page navigation" hidden>
        <button class="blog-listing__page-btn" data-action="prev" type="button">
          ← Previous
        </button>
        <span class="blog-listing__page-status">Page 1 of 1</span>
        <button class="blog-listing__page-btn" data-action="next" type="button">
          Next →
        </button>
      </nav>

      <p class="blog-listing__empty-filter" hidden>
        No posts in this topic yet.
      </p>
    </div>
  </section>
</BaseLayout>

<script>
  /**
   * Pagination + topic filter for the blog index (Vikunja #115).
   *
   * All cards are statically rendered. The script hides cards outside
   * the current topic AND outside the current page slice, then updates
   * the chip + dropdown + page nav state. No fetch, no JSON globals —
   * the DOM is already the source of truth.
   */
  const STORAGE_KEY = 'wm-blog-page-size';
  const VALID_PAGE_SIZES = [25, 50, 100] as const;
  const VALID_TOPICS = [
    'all',
    'vocabulary',
    'writing',
    'announcement',
    'learning-science',
    'story',
  ];

  const grid = document.querySelector<HTMLElement>('.blog-listing__grid');
  const chips = Array.from(
    document.querySelectorAll<HTMLButtonElement>('.blog-listing__chip'),
  );
  const sizeSelect = document.getElementById('blog-page-size') as HTMLSelectElement | null;
  const pagination = document.querySelector<HTMLElement>('.blog-listing__pagination');
  const pageStatus = document.querySelector<HTMLElement>('.blog-listing__page-status');
  const prevBtn = document.querySelector<HTMLButtonElement>('[data-action="prev"]');
  const nextBtn = document.querySelector<HTMLButtonElement>('[data-action="next"]');
  const emptyFilter = document.querySelector<HTMLElement>('.blog-listing__empty-filter');

  if (grid && chips.length > 0 && sizeSelect && pagination && pageStatus && prevBtn && nextBtn && emptyFilter) {
    const allCards = Array.from(grid.querySelectorAll<HTMLElement>('.blog-card'));

    type PageSize = (typeof VALID_PAGE_SIZES)[number];
    function coerceSize(raw: string | null): PageSize {
      const n = Number(raw);
      return (VALID_PAGE_SIZES as readonly number[]).includes(n) ? (n as PageSize) : 25;
    }
    function coerceTopic(raw: string | null): string {
      return raw && VALID_TOPICS.includes(raw) ? raw : 'all';
    }

    /** Read URL params first (shareable), then localStorage (sticky size). */
    const params = new URLSearchParams(window.location.search);
    let currentTopic = coerceTopic(params.get('topic'));
    let currentSize = coerceSize(params.get('perPage') ?? localStorage.getItem(STORAGE_KEY));
    let currentPage = Math.max(1, parseInt(params.get('page') ?? '1', 10) || 1);

    sizeSelect.value = String(currentSize);

    function applyState(updateUrl = true): void {
      // 1. Filter by topic.
      const filtered = currentTopic === 'all'
        ? allCards
        : allCards.filter((c) => c.dataset.topic === currentTopic);

      // 2. Compute pagination over the filtered set.
      const totalPages = Math.max(1, Math.ceil(filtered.length / currentSize));
      if (currentPage > totalPages) currentPage = totalPages;

      const start = (currentPage - 1) * currentSize;
      const end = start + currentSize;
      const visible = new Set(filtered.slice(start, end));

      // 3. Hide / show.
      for (const card of allCards) {
        card.hidden = !visible.has(card);
      }
      emptyFilter!.hidden = filtered.length > 0;

      // 4. Page nav.
      pagination!.hidden = filtered.length <= currentSize;
      pageStatus!.textContent = `Page ${currentPage} of ${totalPages}`;
      prevBtn!.disabled = currentPage <= 1;
      nextBtn!.disabled = currentPage >= totalPages;

      // 5. Chip aria state.
      for (const chip of chips) {
        const active = chip.dataset.topic === currentTopic;
        chip.setAttribute('aria-pressed', active ? 'true' : 'false');
      }

      // 6. URL state — sticky page + topic for back-button / share.
      if (updateUrl) {
        const next = new URLSearchParams();
        if (currentTopic !== 'all') next.set('topic', currentTopic);
        if (currentPage > 1) next.set('page', String(currentPage));
        if (currentSize !== 25) next.set('perPage', String(currentSize));
        const qs = next.toString();
        const url = qs ? `${window.location.pathname}?${qs}` : window.location.pathname;
        window.history.replaceState(null, '', url);
      }
    }

    // Wire chips.
    for (const chip of chips) {
      chip.addEventListener('click', () => {
        const t = chip.dataset.topic;
        if (!t) return;
        currentTopic = coerceTopic(t);
        currentPage = 1;
        applyState();
      });
    }

    // Wire page-size dropdown + persist to localStorage.
    sizeSelect.addEventListener('change', () => {
      currentSize = coerceSize(sizeSelect.value);
      currentPage = 1;
      try {
        localStorage.setItem(STORAGE_KEY, String(currentSize));
      } catch {
        // Storage blocked (incognito, etc) — silently continue. Size
        // applies for this session only.
      }
      applyState();
    });

    // Page nav.
    prevBtn.addEventListener('click', () => {
      if (currentPage > 1) {
        currentPage--;
        applyState();
        window.scrollTo({ behavior: 'smooth', top: 0 });
      }
    });
    nextBtn.addEventListener('click', () => {
      currentPage++;
      applyState();
      window.scrollTo({ behavior: 'smooth', top: 0 });
    });

    applyState(false);
  }
</script>

<style>
  .blog-listing__filters {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    justify-content: space-between;
    margin: 0 auto 24px;
    max-width: 1100px;
  }

  .blog-listing__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .blog-listing__chip {
    background: var(--color-bg-alt, #f5f7fb);
    border: 1px solid var(--color-border, #d1d5db);
    border-radius: 999px;
    color: var(--color-text);
    cursor: pointer;
    font-size: 0.85rem;
    font-weight: 600;
    padding: 6px 14px;
    transition: all 0.15s ease;
  }
  .blog-listing__chip:hover {
    border-color: var(--color-primary, #2563eb);
    color: var(--color-primary, #2563eb);
  }
  .blog-listing__chip[aria-pressed="true"] {
    background: var(--color-primary, #2563eb);
    border-color: var(--color-primary, #2563eb);
    color: #fff;
  }
  .blog-listing__chip-count {
    font-weight: 500;
    opacity: 0.75;
  }

  .blog-listing__page-size {
    align-items: center;
    color: var(--color-text-secondary);
    display: flex;
    font-size: 0.9rem;
    gap: 8px;
  }
  .blog-listing__page-size select {
    background: var(--color-bg-alt, #f5f7fb);
    border: 1px solid var(--color-border, #d1d5db);
    border-radius: 6px;
    color: var(--color-text);
    cursor: pointer;
    font-size: 0.9rem;
    padding: 6px 10px;
  }

  .blog-card__topic {
    background: #dbeafe;
    border-radius: 999px;
    color: #1e40af;
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    margin-bottom: 10px;
    padding: 3px 10px;
    text-transform: uppercase;
  }
  .blog-card__topic[data-topic="writing"]          { background: #ede9fe; color: #5b21b6; }
  .blog-card__topic[data-topic="announcement"]     { background: #d1fae5; color: #065f46; }
  .blog-card__topic[data-topic="learning-science"] { background: #ffedd5; color: #9a3412; }
  .blog-card__topic[data-topic="story"]            { background: #ffe4e6; color: #9f1239; }

  .blog-listing__pagination {
    align-items: center;
    display: flex;
    gap: 16px;
    justify-content: center;
    margin: 40px 0 8px;
  }
  .blog-listing__page-btn {
    background: transparent;
    border: 1px solid var(--color-border, #d1d5db);
    border-radius: 6px;
    color: var(--color-text);
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 600;
    padding: 8px 18px;
    transition: all 0.15s ease;
  }
  .blog-listing__page-btn:hover:not(:disabled) {
    background: var(--color-primary, #2563eb);
    border-color: var(--color-primary, #2563eb);
    color: #fff;
  }
  .blog-listing__page-btn:disabled {
    cursor: not-allowed;
    opacity: 0.4;
  }
  .blog-listing__page-status {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
  }

  .blog-listing__empty-filter {
    color: var(--color-text-secondary);
    margin: 40px 0;
    text-align: center;
  }

  @media (max-width: 600px) {
    .blog-listing__filters {
      flex-direction: column;
      align-items: stretch;
    }
    .blog-listing__page-size {
      justify-content: flex-end;
    }
  }
</style>
