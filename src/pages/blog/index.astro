---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogSearch from '../../components/BlogSearch.astro';
import { SITE_NAME } from '../../consts';
import { fetchPublishedArticles } from '../../lib/blog-articles';

/**
 * Blog index — now sourced from the admin API at build time (Vikunja #76)
 * instead of `getCollection('blog')` over local .md files. The article
 * row is the source of truth; the landing site is a stale-on-deploy
 * snapshot rebuilt by the landing Jenkins job after publishing.
 */
const posts = await fetchPublishedArticles();
---

<BaseLayout
  title={`Blog — ${SITE_NAME}`}
  description={`Tips, strategies, and updates from the ${SITE_NAME} team to help you master vocabulary.`}
  canonicalPath="/blog/"
  currentPage="blog"
>
  <section class="blog-listing">
    <div class="container">
      <div class="blog-listing__header">
        <h1>Blog</h1>
        <p>Tips, strategies, and updates to help you master vocabulary like never before.</p>
      </div>

      <BlogSearch />

      <div class="blog-listing__grid">
        {posts.map((post) => {
          const pubDate = post.publishedAt ? new Date(post.publishedAt) : new Date(post.createdAt);
          const formattedDate = pubDate.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          });
          return (
            <a href={`/blog/${post.slug}/`} class="blog-card fade-in">
              <div class="blog-card__content">
                <time datetime={pubDate.toISOString()}>{formattedDate}</time>
                <h2>{post.title}</h2>
                <p>{post.description}</p>
              </div>
            </a>
          );
        })}
        {posts.length === 0 && (
          <p class="blog-listing__empty">No articles published yet. Check back soon.</p>
        )}
      </div>
    </div>
  </section>
</BaseLayout>
