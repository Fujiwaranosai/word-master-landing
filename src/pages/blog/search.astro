---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogSearch from '../../components/BlogSearch.astro';
import { SITE_NAME } from '../../consts';

/**
 * Blog search results page (Vikunja #121, #122).
 *
 * The previous UX dumped highlighted results into an inline dropdown on
 * the /blog/ page, which was distracting and offered no shareable URL.
 * The new flow:
 *   - typing on /blog/ does NOTHING visually
 *   - Enter (or clicking the search icon) navigates here with ?q=…
 *   - this page fetches `${PUBLIC_BLOG_API_BASE_URL}/blog/search` from
 *     the browser and renders cards
 *
 * The site is fully static (`output: 'static'` in astro.config.mjs), so
 * arbitrary `q` values cannot be SSR-rendered — the cards are built
 * client-side. The shell (title, search box, empty container) is shipped
 * at build time so the page is interactive immediately; a tiny script
 * fills in the cards once the fetch resolves.
 *
 * `highlightTitle` / `highlightBody` come back from the backend as
 * pre-rendered HTML with `<mark>` tags. We escape everything except the
 * mark tags before innerHTML so we don't inherit XSS surface beyond
 * what the backend already controls.
 */
const apiBaseUrl =
  import.meta.env.PUBLIC_BLOG_API_BASE_URL ??
  process.env.BLOG_API_BASE_URL ??
  'http://api.word-master.local';
---

<BaseLayout
  title={`Search — ${SITE_NAME} Blog`}
  description={`Search articles on the ${SITE_NAME} blog.`}
  canonicalPath="/blog/search/"
  currentPage="blog"
  noindex
>
  <section class="blog-listing">
    <div class="container">
      <nav class="blog-listing__breadcrumb" aria-label="Breadcrumb">
        <a href="/blog/">&larr; All posts</a>
      </nav>

      <div class="blog-listing__header">
        <h1>Search</h1>
        <p data-search-summary>Enter a query to search the blog.</p>
      </div>

      <BlogSearch />

      <div
        class="blog-search-results"
        data-blog-search-results
        data-api-base-url={apiBaseUrl}
      >
        <p class="blog-search-results__status" data-search-status hidden></p>
        <ul class="blog-search-results__list" data-search-list></ul>
        <nav
          class="blog-search-results__pagination"
          aria-label="Search results pagination"
          data-search-pagination
          hidden
        >
          <button
            class="blog-search-results__page-btn"
            type="button"
            data-search-prev
          >
            &larr; Previous
          </button>
          <span class="blog-search-results__page-status" data-search-page-status>
            Page 1
          </span>
          <button
            class="blog-search-results__page-btn"
            type="button"
            data-search-next
          >
            Next &rarr;
          </button>
        </nav>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  /**
   * Client-side search renderer. The static shell ships first; this
   * script reads `?q=…&page=…` from the URL, populates the input, fires
   * the fetch, and paints cards into the container above.
   */
  interface SearchHit {
    articleId: string;
    author?: string;
    description: string;
    heroImageUrl: string | null;
    highlightBody: string | null;
    highlightTitle: string | null;
    publishedAt: number;
    slug: string;
    tags: string[];
    title: string;
    topic: string;
  }
  interface SearchResponse {
    data: {
      hits: SearchHit[];
      page?: number;
      perPage?: number;
      status?: 'unavailable';
      total: number;
    };
    success: boolean;
  }

  const container = document.querySelector<HTMLElement>('[data-blog-search-results]');
  const listEl = document.querySelector<HTMLUListElement>('[data-search-list]');
  const statusEl = document.querySelector<HTMLElement>('[data-search-status]');
  const summaryEl = document.querySelector<HTMLElement>('[data-search-summary]');
  const paginationEl = document.querySelector<HTMLElement>('[data-search-pagination]');
  const pageStatusEl = document.querySelector<HTMLElement>('[data-search-page-status]');
  const prevBtn = document.querySelector<HTMLButtonElement>('[data-search-prev]');
  const nextBtn = document.querySelector<HTMLButtonElement>('[data-search-next]');
  const input = document.getElementById('blog-search-input') as HTMLInputElement | null;

  if (
    container &&
    listEl &&
    statusEl &&
    summaryEl &&
    paginationEl &&
    pageStatusEl &&
    prevBtn &&
    nextBtn &&
    input
  ) {
    const apiBaseUrl = container.dataset.apiBaseUrl ?? '';

    // Drop-stale-response guard: only the latest request's render wins
    // even when the user clicks Next/Prev quickly.
    let currentRequest = 0;

    function escapeHtml(s: string): string {
      const div = document.createElement('div');
      div.textContent = s;
      return div.innerHTML;
    }

    /** Backend ships `<mark>…</mark>` inside highlighted strings. Escape
     *  everything else so any other HTML in the text is rendered as
     *  literal characters, not parsed. */
    function escapeAllowMark(s: string): string {
      const parts = s.split(/(<\/?mark>)/gi);
      return parts
        .map((p) => (p.match(/<\/?mark>/i) ? p.toLowerCase() : escapeHtml(p)))
        .join('');
    }

    function formatDate(unixSec: number): string {
      const d = new Date(unixSec * 1000);
      return d.toLocaleDateString('en-US', {
        day: 'numeric',
        month: 'long',
        year: 'numeric',
      });
    }

    function topicLabel(topic: string): string {
      return topic.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
    }

    function renderHits(hits: SearchHit[]): string {
      return hits
        .map((h) => {
          const titleHtml = h.highlightTitle
            ? escapeAllowMark(h.highlightTitle)
            : escapeHtml(h.title);
          const bodyHtml = h.highlightBody
            ? escapeAllowMark(h.highlightBody)
            : escapeHtml(h.description);
          const tagsHtml = (h.tags ?? [])
            .map((t) => `<span class="blog-search-results__tag">${escapeHtml(t)}</span>`)
            .join('');
          // The entire card is wrapped in an anchor so clicking anywhere
          // on it navigates to the article.
          return `
            <li class="blog-search-results__hit">
              <a href="/blog/${escapeHtml(h.slug)}/" class="blog-search-results__hit-link">
                <div class="blog-search-results__hit-meta">
                  <span class="blog-search-results__hit-topic" data-topic="${escapeHtml(h.topic)}">${escapeHtml(topicLabel(h.topic))}</span>
                  <time class="blog-search-results__hit-date" datetime="${new Date(h.publishedAt * 1000).toISOString()}">${formatDate(h.publishedAt)}</time>
                </div>
                <h2 class="blog-search-results__hit-title">${titleHtml}</h2>
                <p class="blog-search-results__hit-snippet">${bodyHtml}</p>
                ${tagsHtml ? `<div class="blog-search-results__tags">${tagsHtml}</div>` : ''}
              </a>
            </li>
          `;
        })
        .join('');
    }

    function setStatus(text: string): void {
      statusEl!.textContent = text;
      statusEl!.hidden = text.length === 0;
    }

    function clearResults(): void {
      listEl!.innerHTML = '';
      paginationEl!.hidden = true;
    }

    function updateUrl(q: string, page: number): void {
      const params = new URLSearchParams();
      params.set('q', q);
      if (page > 1) params.set('page', String(page));
      const url = `${window.location.pathname}?${params.toString()}`;
      window.history.replaceState(null, '', url);
    }

    async function runSearch(q: string, page: number): Promise<void> {
      const requestId = ++currentRequest;
      setStatus('Searching…');
      clearResults();
      try {
        const url = `${apiBaseUrl}/blog/search?q=${encodeURIComponent(q)}&page=${page}`;
        const res = await fetch(url);
        if (requestId !== currentRequest) return; // stale
        if (!res.ok) {
          setStatus('Search temporarily unavailable.');
          summaryEl!.textContent = '';
          return;
        }
        const body = (await res.json()) as SearchResponse;
        if (requestId !== currentRequest) return;

        if (body.data.status === 'unavailable') {
          setStatus('Search temporarily unavailable.');
          summaryEl!.textContent = '';
          return;
        }

        const total = body.data.total ?? 0;
        const perPage = body.data.perPage ?? 10;
        const currentPage = body.data.page ?? page;
        const totalPages = Math.max(1, Math.ceil(total / perPage));

        if (total === 0) {
          setStatus('');
          summaryEl!.textContent = '';
          // Empty state — show inline in the list area for visibility.
          listEl!.innerHTML = `
            <li class="blog-search-results__empty">
              No results found for &ldquo;${escapeHtml(q)}&rdquo;.
            </li>
          `;
          return;
        }

        setStatus('');
        summaryEl!.textContent = `${total} result${total === 1 ? '' : 's'} for "${q}"`;
        listEl!.innerHTML = renderHits(body.data.hits);

        // Pagination — only show when there's more than one page.
        if (totalPages > 1) {
          paginationEl!.hidden = false;
          pageStatusEl!.textContent = `Page ${currentPage} of ${totalPages}`;
          prevBtn!.disabled = currentPage <= 1;
          nextBtn!.disabled = currentPage >= totalPages;
        } else {
          paginationEl!.hidden = true;
        }
      } catch (err) {
        if (requestId !== currentRequest) return;
        setStatus('Search temporarily unavailable.');
        summaryEl!.textContent = '';
      }
    }

    // Read query from the URL — this is what makes the page bookmarkable
    // and gives Back/Forward something to land on.
    const params = new URLSearchParams(window.location.search);
    // Defense-in-depth cap on query length so a pathological URL can't
    // send an unbounded string to the backend (matches the input's
    // maxlength="200" attribute).
    const q = (params.get('q') ?? '').slice(0, 200).trim();
    const page = Math.max(1, parseInt(params.get('page') ?? '1', 10) || 1);

    // Always pre-fill the search box from the URL so users can edit
    // their query without re-typing it.
    input.value = q;
    // Trigger the clear button's visibility sync.
    input.dispatchEvent(new Event('input', { bubbles: true }));

    if (q.length > 0) {
      summaryEl.textContent = '';
      runSearch(q, page);
    }

    // Pagination handlers — re-fire the search with the next page and
    // update the URL so the back button works.
    prevBtn.addEventListener('click', () => {
      const params = new URLSearchParams(window.location.search);
      const q = (params.get('q') ?? '').trim();
      const current = Math.max(1, parseInt(params.get('page') ?? '1', 10) || 1);
      if (!q || current <= 1) return;
      const next = current - 1;
      updateUrl(q, next);
      runSearch(q, next);
      window.scrollTo({ behavior: 'smooth', top: 0 });
    });
    nextBtn.addEventListener('click', () => {
      const params = new URLSearchParams(window.location.search);
      const q = (params.get('q') ?? '').trim();
      const current = Math.max(1, parseInt(params.get('page') ?? '1', 10) || 1);
      if (!q) return;
      const next = current + 1;
      updateUrl(q, next);
      runSearch(q, next);
      window.scrollTo({ behavior: 'smooth', top: 0 });
    });
  }
</script>

<style>
  .blog-listing__breadcrumb {
    color: var(--color-text-secondary);
    font-size: 0.8125rem;
    margin: 0 auto 16px;
    max-width: 1100px;
  }
  .blog-listing__breadcrumb a {
    color: inherit;
    text-decoration: none;
    letter-spacing: 0.02em;
  }
  .blog-listing__breadcrumb a:hover {
    color: var(--color-primary);
    text-decoration: underline;
  }

  .blog-search-results {
    margin: 0 auto;
    max-width: 760px;
  }

  .blog-search-results__status {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    margin: 0 0 16px;
    text-align: center;
  }

  .blog-search-results__list {
    display: grid;
    gap: 16px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .blog-search-results__hit {
    background: var(--color-bg, #fff);
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: 12px;
    transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
  }
  .blog-search-results__hit:hover {
    border-color: var(--color-primary, #2563eb);
    box-shadow: 0 6px 20px rgba(37, 99, 235, 0.12);
    transform: translateY(-2px);
  }
  .blog-search-results__hit-link {
    color: inherit;
    display: block;
    padding: 22px 24px;
    text-decoration: none;
  }
  .blog-search-results__hit-link:hover {
    color: inherit;
  }
  .blog-search-results__hit-meta {
    align-items: center;
    display: flex;
    gap: 12px;
    margin-bottom: 10px;
  }
  .blog-search-results__hit-topic {
    background: #dbeafe;
    border-radius: 999px;
    color: #1e40af;
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    padding: 3px 10px;
    text-transform: uppercase;
  }
  .blog-search-results__hit-topic[data-topic="writing"]          { background: #ede9fe; color: #5b21b6; }
  .blog-search-results__hit-topic[data-topic="announcement"]     { background: #d1fae5; color: #065f46; }
  .blog-search-results__hit-topic[data-topic="learning-science"] { background: #ffedd5; color: #9a3412; }
  .blog-search-results__hit-topic[data-topic="story"]            { background: #ffe4e6; color: #9f1239; }
  .blog-search-results__hit-date {
    color: var(--color-text-secondary);
    font-size: 0.8125rem;
  }
  .blog-search-results__hit-title {
    color: var(--color-text);
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.3;
    margin: 0 0 8px;
  }
  .blog-search-results__hit-snippet {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
    /* Preserve newlines coming back from highlightBody so paragraph
       breaks render the way the backend laid them out. */
    white-space: pre-wrap;
  }
  /* The mark tags ship inside highlightTitle/highlightBody — keep the
     same yellow accent the inline dropdown used. */
  .blog-search-results__hit-title :global(mark),
  .blog-search-results__hit-snippet :global(mark) {
    background: #fef3c7;
    border-radius: 2px;
    color: inherit;
    padding: 0 2px;
  }

  .blog-search-results__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 12px;
  }
  .blog-search-results__tag {
    background: var(--color-primary-light);
    border-radius: 100px;
    color: var(--color-primary-on-light);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 3px 10px;
  }

  .blog-search-results__empty {
    background: var(--color-bg-alt, #f5f7fb);
    border: 1px dashed var(--color-border, #d1d5db);
    border-radius: 12px;
    color: var(--color-text-secondary);
    font-size: 1rem;
    list-style: none;
    margin: 0;
    padding: 36px 20px;
    text-align: center;
  }

  .blog-search-results__pagination {
    align-items: center;
    display: flex;
    gap: 16px;
    justify-content: center;
    margin: 32px 0 8px;
  }
  .blog-search-results__page-btn {
    background: transparent;
    border: 1px solid var(--color-border, #d1d5db);
    border-radius: 6px;
    color: var(--color-text);
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 600;
    padding: 8px 18px;
    transition: all 0.15s ease;
  }
  .blog-search-results__page-btn:hover:not(:disabled) {
    background: var(--color-primary, #2563eb);
    border-color: var(--color-primary, #2563eb);
    color: #fff;
  }
  .blog-search-results__page-btn:disabled {
    cursor: not-allowed;
    opacity: 0.4;
  }
  .blog-search-results__page-status {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
  }

  @media (max-width: 600px) {
    .blog-search-results__hit-link {
      padding: 18px 18px;
    }
    .blog-search-results__hit-meta {
      flex-wrap: wrap;
    }
  }
</style>
