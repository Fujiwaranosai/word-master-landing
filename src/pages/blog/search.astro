---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogSearch from '../../components/BlogSearch.astro';
import { SITE_NAME } from '../../consts';

/**
 * Blog search results page (Vikunja #121, #122).
 *
 * The previous UX dumped highlighted results into an inline dropdown on
 * the /blog/ page, which was distracting and offered no shareable URL.
 * The new flow:
 *   - typing on /blog/ does NOTHING visually
 *   - Enter (or clicking the search icon) navigates here with ?q=…
 *   - this page fetches `${PUBLIC_BLOG_API_BASE_URL}/blog/search` from
 *     the browser and renders cards
 *
 * The site is fully static (`output: 'static'` in astro.config.mjs), so
 * arbitrary `q` values cannot be SSR-rendered — the cards are built
 * client-side. The shell (title, search box, empty container) is shipped
 * at build time so the page is interactive immediately; a tiny script
 * fills in the cards once the fetch resolves.
 *
 * `highlightTitle` / `highlightBody` come back from the backend as
 * pre-rendered HTML with `<mark>` tags. We escape everything except the
 * mark tags before innerHTML so we don't inherit XSS surface beyond
 * what the backend already controls.
 */
const apiBaseUrl =
  import.meta.env.PUBLIC_BLOG_API_BASE_URL ??
  process.env.BLOG_API_BASE_URL ??
  'http://api.word-master.local';
---

<BaseLayout
  title={`Search — ${SITE_NAME} Blog`}
  description={`Search articles on the ${SITE_NAME} blog.`}
  canonicalPath="/blog/search/"
  currentPage="blog"
  noindex
>
  <section class="blog-listing">
    <div class="container">
      <nav class="blog-listing__breadcrumb" aria-label="Breadcrumb">
        <a href="/blog/">&larr; All posts</a>
      </nav>

      <div class="blog-listing__header">
        <h1>Search</h1>
        <p data-search-summary>Enter a query to search the blog.</p>
      </div>

      <BlogSearch />

      <div
        class="blog-search-results"
        data-blog-search-results
        data-api-base-url={apiBaseUrl}
      >
        <p class="blog-search-results__status" data-search-status hidden></p>
        {/* Reuse the same .blog-listing__grid + .blog-card markup as the
            blog index so search-result cards visually match the regular
            listing exactly. Cards are injected client-side by the script
            below. */}
        <div class="blog-listing__grid" data-search-list></div>
        <nav
          class="blog-listing__pagination"
          aria-label="Search results pagination"
          data-search-pagination
          hidden
        >
          <button
            class="blog-listing__page-btn"
            type="button"
            data-search-prev
          >
            &larr; Previous
          </button>
          <span class="blog-listing__page-status" data-search-page-status>
            Page 1
          </span>
          <button
            class="blog-listing__page-btn"
            type="button"
            data-search-next
          >
            Next &rarr;
          </button>
        </nav>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  /**
   * Client-side search renderer. The static shell ships first; this
   * script reads `?q=…&page=…` from the URL, populates the input, fires
   * the fetch, and paints cards into the container above.
   */
  interface SearchHit {
    articleId: string;
    author?: string;
    description: string;
    heroImageUrl: string | null;
    highlightBody: string | null;
    highlightTitle: string | null;
    publishedAt: number;
    slug: string;
    tags: string[];
    title: string;
    topic: string;
  }
  interface SearchResponse {
    data: {
      hits: SearchHit[];
      page?: number;
      perPage?: number;
      status?: 'unavailable';
      total: number;
    };
    success: boolean;
  }

  const container = document.querySelector<HTMLElement>('[data-blog-search-results]');
  const listEl = document.querySelector<HTMLUListElement>('[data-search-list]');
  const statusEl = document.querySelector<HTMLElement>('[data-search-status]');
  const summaryEl = document.querySelector<HTMLElement>('[data-search-summary]');
  const paginationEl = document.querySelector<HTMLElement>('[data-search-pagination]');
  const pageStatusEl = document.querySelector<HTMLElement>('[data-search-page-status]');
  const prevBtn = document.querySelector<HTMLButtonElement>('[data-search-prev]');
  const nextBtn = document.querySelector<HTMLButtonElement>('[data-search-next]');
  const input = document.getElementById('blog-search-input') as HTMLInputElement | null;

  if (
    container &&
    listEl &&
    statusEl &&
    summaryEl &&
    paginationEl &&
    pageStatusEl &&
    prevBtn &&
    nextBtn &&
    input
  ) {
    const apiBaseUrl = container.dataset.apiBaseUrl ?? '';

    // Drop-stale-response guard: only the latest request's render wins
    // even when the user clicks Next/Prev quickly.
    let currentRequest = 0;

    function escapeHtml(s: string): string {
      const div = document.createElement('div');
      div.textContent = s;
      return div.innerHTML;
    }

    /** Backend ships `<mark>…</mark>` inside highlighted strings. Escape
     *  everything else so any other HTML in the text is rendered as
     *  literal characters, not parsed. */
    function escapeAllowMark(s: string): string {
      const parts = s.split(/(<\/?mark>)/gi);
      return parts
        .map((p) => (p.match(/<\/?mark>/i) ? p.toLowerCase() : escapeHtml(p)))
        .join('');
    }

    function formatDate(unixSec: number): string {
      const d = new Date(unixSec * 1000);
      return d.toLocaleDateString('en-US', {
        day: 'numeric',
        month: 'long',
        year: 'numeric',
      });
    }

    /** Topic-slug → display label. Mirrors ARTICLE_TOPIC_LABELS in
     *  word-master-backend's articles.constants.ts (kept in sync with
     *  the blog index page). Unknown slugs fall back to title-cased
     *  text so a future enum addition still renders sensibly. */
    const TOPIC_LABELS: Record<string, string> = {
      vocabulary: 'Vocabulary',
      writing: 'Writing',
      announcement: 'Announcement',
      'learning-science': 'Learning Science',
      story: 'Story',
    };
    function topicLabel(topic: string): string {
      return TOPIC_LABELS[topic] ?? topic.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
    }

    function renderHits(hits: SearchHit[]): string {
      return hits
        .map((h) => {
          const titleHtml = h.highlightTitle
            ? escapeAllowMark(h.highlightTitle)
            : escapeHtml(h.title);
          const bodyHtml = h.highlightBody
            ? escapeAllowMark(h.highlightBody)
            : escapeHtml(h.description);
          // Mirror the blog-index card markup exactly so search results
          // look identical to the listing — same .blog-card class,
          // same inner structure, same topic chip + date + h2 + p
          // shape. The only difference is that <h2> and <p> may carry
          // <mark> spans from the backend highlights.
          // NOTE: do NOT add `fade-in` here. That class ships with
          // opacity: 0 and waits for the page-load IntersectionObserver
          // to add `.visible`. The observer only scans the static SSR
          // markup once at load; dynamically-injected cards never get
          // observed, so they'd stay invisible (cursor hover would
          // still detect the anchor — the exact symptom we just fixed).
          return `
            <a
              href="/blog/${escapeHtml(h.slug)}/"
              class="blog-card"
              data-topic="${escapeHtml(h.topic)}"
            >
              <div class="blog-card__content">
                <span class="blog-card__topic" data-topic="${escapeHtml(h.topic)}">${escapeHtml(topicLabel(h.topic))}</span>
                <time datetime="${new Date(h.publishedAt * 1000).toISOString()}">${formatDate(h.publishedAt)}</time>
                <h2>${titleHtml}</h2>
                <p>${bodyHtml}</p>
              </div>
            </a>
          `;
        })
        .join('');
    }

    function setStatus(text: string): void {
      statusEl!.textContent = text;
      statusEl!.hidden = text.length === 0;
    }

    function clearResults(): void {
      listEl!.innerHTML = '';
      paginationEl!.hidden = true;
    }

    function updateUrl(q: string, page: number): void {
      const params = new URLSearchParams();
      params.set('q', q);
      if (page > 1) params.set('page', String(page));
      const url = `${window.location.pathname}?${params.toString()}`;
      window.history.replaceState(null, '', url);
    }

    async function runSearch(q: string, page: number): Promise<void> {
      const requestId = ++currentRequest;
      setStatus('Searching…');
      clearResults();
      try {
        const url = `${apiBaseUrl}/blog/search?q=${encodeURIComponent(q)}&page=${page}`;
        const res = await fetch(url);
        if (requestId !== currentRequest) return; // stale
        if (!res.ok) {
          setStatus('Search temporarily unavailable.');
          summaryEl!.textContent = '';
          return;
        }
        const body = (await res.json()) as SearchResponse;
        if (requestId !== currentRequest) return;

        if (body.data.status === 'unavailable') {
          setStatus('Search temporarily unavailable.');
          summaryEl!.textContent = '';
          return;
        }

        const total = body.data.total ?? 0;
        const perPage = body.data.perPage ?? 10;
        const currentPage = body.data.page ?? page;
        const totalPages = Math.max(1, Math.ceil(total / perPage));

        if (total === 0) {
          setStatus('');
          summaryEl!.textContent = '';
          // Empty state — reuse the listing page's empty-state class so
          // it visually matches the rest of the blog area.
          listEl!.innerHTML = `
            <p class="blog-listing__empty">
              No results found for &ldquo;${escapeHtml(q)}&rdquo;.
            </p>
          `;
          return;
        }

        setStatus('');
        summaryEl!.textContent = `${total} result${total === 1 ? '' : 's'} for "${q}"`;
        listEl!.innerHTML = renderHits(body.data.hits);

        // Pagination — only show when there's more than one page.
        if (totalPages > 1) {
          paginationEl!.hidden = false;
          pageStatusEl!.textContent = `Page ${currentPage} of ${totalPages}`;
          prevBtn!.disabled = currentPage <= 1;
          nextBtn!.disabled = currentPage >= totalPages;
        } else {
          paginationEl!.hidden = true;
        }
      } catch (err) {
        if (requestId !== currentRequest) return;
        setStatus('Search temporarily unavailable.');
        summaryEl!.textContent = '';
      }
    }

    // Read query from the URL — this is what makes the page bookmarkable
    // and gives Back/Forward something to land on.
    const params = new URLSearchParams(window.location.search);
    // Defense-in-depth cap on query length so a pathological URL can't
    // send an unbounded string to the backend (matches the input's
    // maxlength="200" attribute).
    const q = (params.get('q') ?? '').slice(0, 200).trim();
    const page = Math.max(1, parseInt(params.get('page') ?? '1', 10) || 1);

    // Always pre-fill the search box from the URL so users can edit
    // their query without re-typing it.
    input.value = q;
    // Trigger the clear button's visibility sync.
    input.dispatchEvent(new Event('input', { bubbles: true }));

    if (q.length > 0) {
      summaryEl.textContent = '';
      runSearch(q, page);
    }

    // Pagination handlers — re-fire the search with the next page and
    // update the URL so the back button works.
    prevBtn.addEventListener('click', () => {
      const params = new URLSearchParams(window.location.search);
      const q = (params.get('q') ?? '').trim();
      const current = Math.max(1, parseInt(params.get('page') ?? '1', 10) || 1);
      if (!q || current <= 1) return;
      const next = current - 1;
      updateUrl(q, next);
      runSearch(q, next);
      window.scrollTo({ behavior: 'smooth', top: 0 });
    });
    nextBtn.addEventListener('click', () => {
      const params = new URLSearchParams(window.location.search);
      const q = (params.get('q') ?? '').trim();
      const current = Math.max(1, parseInt(params.get('page') ?? '1', 10) || 1);
      if (!q) return;
      const next = current + 1;
      updateUrl(q, next);
      runSearch(q, next);
      window.scrollTo({ behavior: 'smooth', top: 0 });
    });
  }
</script>

<style>
  .blog-listing__breadcrumb {
    color: var(--color-text-secondary);
    font-size: 0.8125rem;
    margin: 0 auto 16px;
    max-width: 1100px;
  }
  .blog-listing__breadcrumb a {
    color: inherit;
    text-decoration: none;
    letter-spacing: 0.02em;
  }
  .blog-listing__breadcrumb a:hover {
    color: var(--color-primary);
    text-decoration: underline;
  }

  /* Only the wrapper + ephemeral status text need bespoke styling here;
     cards reuse .blog-card from blog-index, empty-state reuses
     .blog-listing__empty, and pagination reuses .blog-listing__pagination
     so search results look identical to the listing. */
  .blog-search-results__status {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    margin: 0 0 16px;
    text-align: center;
  }

  /* <mark> spans inside the backend's highlightTitle/highlightBody. The
     `:global()` wrapper is required because the markup is injected via
     innerHTML, which Astro's scoped-style hashing can't reach. */
  .blog-card :global(mark) {
    background: #fef3c7;
    border-radius: 2px;
    color: inherit;
    padding: 0 2px;
  }
</style>
