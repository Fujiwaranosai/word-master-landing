---
import BaseLayout from '../layouts/BaseLayout.astro';
import FinalCta from '../components/FinalCta.astro';
import { SITE_NAME, APP_URL } from '../consts';
---

<BaseLayout
  title={`${SITE_NAME} — Master Words, Not Just Memorize Them`}
  description="Learn vocabulary the way your brain works — through nuance, context, and real usage. Powered by AI. Free to start."
  ogTitle={`${SITE_NAME} — Master Words, Not Just Memorize Them`}
  ogDescription="Learn vocabulary the way your brain works — through nuance, context, and real usage. Powered by AI."
  twitterCard="summary_large_image"
  canonicalPath="/"
  currentPage="home"
>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero__badge">AI-Powered Vocabulary Learning</div>
      <h1>Master Words, Not Just Memorize Them</h1>
      <p class="hero__sub">Learn vocabulary the way your brain works &mdash; through nuance, context, and real usage. Powered by AI.</p>
      <div class="hero__actions">
        <a href={APP_URL} class="btn btn--primary btn--large" data-ga-cta="get_started_free" data-ga-location="hero">Get Started Free</a>
        <a href="/pricing/" class="btn btn--secondary btn--large" data-ga-cta="see_pricing" data-ga-location="hero">See Pricing</a>
      </div>
      <div class="hero__visual">
        <img
          class="hero__image"
          src="/images/hero-word-detail.png"
          alt="The 'Related Words & Nuances' card in Vocab Mine showing six near-synonyms for the word ephemeral — transient, fleeting, momentary, evanescent, temporary, impermanent — each with a nuance explanation and example sentences."
          width="852"
          height="1112"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </section>

  <!-- Problem Statement -->
  <section class="problem section section--alt" id="problem">
    <div class="container">
      <p class="problem__quote fade-in">&ldquo;Flashcard apps teach you definitions. But knowing a definition isn&rsquo;t knowing a word.&rdquo;</p>
      <div class="problem__points">
        <div class="problem__point fade-in">
          <div class="problem__icon">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 4v6l4 2" stroke="#ef4444" stroke-width="2" stroke-linecap="round"/><circle cx="10" cy="10" r="8" stroke="#ef4444" stroke-width="2"/></svg>
          </div>
          <div>
            <strong>Synonyms feel interchangeable</strong>
            <p>You learned "happy" and "glad" mean the same thing &mdash; but they don't. Not exactly.</p>
          </div>
        </div>
        <div class="problem__point fade-in">
          <div class="problem__icon">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M6 10h8M10 6v8" stroke="#ef4444" stroke-width="2" stroke-linecap="round"/><circle cx="10" cy="10" r="8" stroke="#ef4444" stroke-width="2"/></svg>
          </div>
          <div>
            <strong>Wrong word, wrong context</strong>
            <p>You know the word, but you use it in awkward or incorrect situations.</p>
          </div>
        </div>
        <div class="problem__point fade-in">
          <div class="problem__icon">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4 16l6-6 6 6M4 10l6-6 6 6" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <div>
            <strong>Can't use words naturally</strong>
            <p>You recognize vocabulary in reading but struggle to produce it in speech or writing.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="section" id="features">
    <div class="container text-center">
      <span class="section__label">Features</span>
      <h2>Everything You Need to Truly Know a Word</h2>
      <p class="section__subtitle">{SITE_NAME} goes beyond definitions to give you deep, contextual understanding of every word you learn.</p>
      <div class="features__grid">
        <div class="feature-card fade-in">
          <div class="feature-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="#2563EB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3>Deep Word Intelligence</h3>
          <p>AI processes each word for IPA pronunciation, multiple definitions, example sentences, phrasal verbs, collocations, idioms, and related words with nuance explanations.</p>
        </div>
        <div class="feature-card fade-in">
          <div class="feature-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="#2563EB" stroke-width="2"/><path d="M8 12l2.5 2.5L16 9" stroke="#2563EB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3>Learn the Nuances</h3>
          <p>Understand subtle differences between similar words. Know when to use "interesting" vs "fascinating" vs "intriguing" &mdash; and why it matters.</p>
        </div>
        <div class="feature-card fade-in">
          <div class="feature-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="7" height="7" rx="1" stroke="#2563EB" stroke-width="2"/><rect x="14" y="3" width="7" height="7" rx="1" stroke="#2563EB" stroke-width="2"/><rect x="3" y="14" width="7" height="7" rx="1" stroke="#2563EB" stroke-width="2"/><rect x="14" y="14" width="7" height="7" rx="1" stroke="#2563EB" stroke-width="2"/></svg>
          </div>
          <h3>5 Learning Modes</h3>
          <p>Meaning Memorization, Nuance Learning, Right Word Selection, Right Sentence Selection, and Writing Practice with AI grading. Progressive skill building from recognition to production.</p>
        </div>
        <div class="feature-card fade-in">
          <div class="feature-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z" stroke="#2563EB" stroke-width="2"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z" stroke="#2563EB" stroke-width="2"/></svg>
          </div>
          <h3>Your Language, Your Way</h3>
          <p>All content translated to your native language with per-item translation toggles. Learn in the way that works best for you.</p>
        </div>
        <div class="feature-card fade-in">
          <div class="feature-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z" stroke="#2563EB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3>Smart Collections &amp; Community</h3>
          <p>Organize words into themed groups, then learn entire collections as packs. Pro learners can share collections to the community and clone what others publish.</p>
        </div>
        <div class="feature-card fade-in">
          <div class="feature-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M22 12h-4l-3 9L9 3l-3 9H2" stroke="#2563EB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3>Track Your Mastery</h3>
          <p>6-level mastery progression that climbs as you practice, with a daily learning streak and a real activity feed of every word added, mastered, and pack completed.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section section--alt" id="how-it-works">
    <div class="container text-center">
      <span class="section__label">How It Works</span>
      <h2>Three Steps to Vocabulary Mastery</h2>
      <p class="section__subtitle">Simple process, powerful results. Start learning in seconds.</p>
      <div class="steps">
        <div class="step fade-in">
          <div class="step__number">1</div>
          <h3>Add Any Word or Phrase</h3>
          <p>Type any English word or phrase. AI processes it in seconds, pulling definitions, pronunciation, examples, and more.</p>
        </div>
        <div class="step fade-in">
          <div class="step__number">2</div>
          <h3>Explore Its Depth</h3>
          <p>See definitions, nuances between similar words, real-world examples, collocations, idioms &mdash; all translated to your language.</p>
        </div>
        <div class="step fade-in">
          <div class="step__number">3</div>
          <h3>Master Through Practice</h3>
          <p>Progressive exercises from flashcards to writing practice. AI grades your output and helps you truly own each word.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="section" id="stats">
    <div class="container text-center">
      <span class="section__label">By the Numbers</span>
      <h2>Built for Serious Learners</h2>
      <div class="stats__grid">
        <div class="stat fade-in">
          <div class="stat__number">5</div>
          <div class="stat__label">Learning Modes</div>
        </div>
        <div class="stat fade-in">
          <div class="stat__number">80+</div>
          <div class="stat__label">Native Languages</div>
        </div>
        <div class="stat fade-in">
          <div class="stat__number">6</div>
          <div class="stat__label">Mastery Levels</div>
        </div>
        <div class="stat fade-in">
          <div class="stat__number">AI</div>
          <div class="stat__label">Powered Processing</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Teaser -->
  <section class="section section--alt" id="pricing">
    <div class="container text-center">
      <span class="section__label">Pricing</span>
      <h2>Start Free, Upgrade Anytime</h2>
      <p class="section__subtitle">Three plans designed to grow with you. Cancel anytime.</p>
      <div class="pricing-teaser__cards">
        <div class="pricing-teaser__card fade-in">
          <h3>Free</h3>
          <ul>
            <li>15 words per month</li>
            <li>5 learning packs per month</li>
            <li>All 5 learning modes</li>
          </ul>
        </div>
        <div class="pricing-teaser__card pricing-teaser__card--pro fade-in">
          <h3>Pro &mdash; $4.99/mo</h3>
          <ul>
            <li>300 words per month</li>
            <li>Unlimited learning packs</li>
            <li>Community sharing &amp; cloning</li>
          </ul>
        </div>
        <div class="pricing-teaser__card pricing-teaser__card--premium fade-in">
          <h3>Premium &mdash; $9.99/mo</h3>
          <ul>
            <li>1,000 words per month</li>
            <li>Priority processing queue</li>
            <li>Advanced learning analytics</li>
          </ul>
        </div>
      </div>
      <a href="/pricing/" class="btn btn--secondary" data-ga-cta="see_full_pricing" data-ga-location="pricing_teaser">See Full Pricing</a>
    </div>
  </section>

  <FinalCta />
</BaseLayout>
