---
import BaseLayout from '../layouts/BaseLayout.astro';
import FinalCta from '../components/FinalCta.astro';
import { SITE_NAME, APP_REGISTER_URL } from '../consts';
---

<BaseLayout
  title={`${SITE_NAME} — Master Words, Not Just Memorize Them`}
  description="Learn vocabulary the way your brain works — through nuance, context, and real usage. Powered by AI. Free to start."
  ogTitle={`${SITE_NAME} — Master Words, Not Just Memorize Them`}
  ogDescription="Learn vocabulary the way your brain works — through nuance, context, and real usage. Powered by AI."
  twitterCard="summary_large_image"
  canonicalPath="/"
  currentPage="home"
>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__copy">
        <div class="hero__badge">Powered by AI</div>
        <h1>Master English Vocabulary with <span class="accent">AI</span></h1>
        <p class="hero__sub">Add words, learn meanings, practice with exercise and master vocabulary faster.</p>
        <div class="hero__actions">
          <a href={APP_REGISTER_URL} class="btn btn--primary btn--large" data-ga-cta="get_started_free" data-ga-location="hero">Get Started Free</a>
          <a href="/#how-it-works" class="btn btn--demo btn--large" data-ga-cta="see_demo" data-ga-location="hero">See Demo</a>
        </div>
      </div>
      <div class="hero__visual">
        <!-- Dashboard preview mock (decorative). aria-hidden so screen
             readers skip the illustrative numbers. -->
        <div class="dash" aria-hidden="true">
          <div class="dash__bar">
            <div class="dash__dots"><span></span><span></span><span></span></div>
            <span class="dash__url">vocabmine.com/dashboard</span>
          </div>
          <div class="dash__row">
            <div class="dash__stat">
              <div class="dash__stat-label">Total Words</div>
              <div class="dash__stat-value">248</div>
              <div class="dash__stat-delta">&uarr; +12 this week</div>
              <div class="dash__track"><div class="dash__fill" style="width: 72%"></div></div>
            </div>
            <div class="dash__stat">
              <div class="dash__stat-label">Mastered</div>
              <div class="dash__stat-value">143</div>
              <div class="dash__stat-delta">&uarr; 58% rate</div>
              <div class="dash__track"><div class="dash__fill" style="width: 58%"></div></div>
            </div>
          </div>
          <div class="dash__recent">
            <div class="dash__recent-title">Recent Words</div>
            <div class="dash__recent-item">
              <span class="dash__recent-word">Insightful</span>
              <span class="dash__chip dash__chip--mastered">Mastered</span>
            </div>
            <div class="dash__recent-item">
              <span class="dash__recent-word">Eloquent</span>
              <span class="dash__chip dash__chip--learning">Learning</span>
            </div>
            <div class="dash__recent-item">
              <span class="dash__recent-word">Resilient</span>
              <span class="dash__chip dash__chip--new">New</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Problem Statement -->
  <section class="problem section section--alt" id="problem">
    <div class="container">
      <p class="problem__quote fade-in">&ldquo;Flashcard apps teach you definitions. But knowing a definition isn&rsquo;t knowing a word.&rdquo;</p>
      <div class="problem__points">
        <div class="problem__point fade-in">
          <div class="problem__icon">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 4v6l4 2" stroke="#ef4444" stroke-width="2" stroke-linecap="round"/><circle cx="10" cy="10" r="8" stroke="#ef4444" stroke-width="2"/></svg>
          </div>
          <div>
            <strong>Synonyms feel interchangeable</strong>
            <p>You learned "happy" and "glad" mean the same thing &mdash; but they don't. Not exactly.</p>
          </div>
        </div>
        <div class="problem__point fade-in">
          <div class="problem__icon">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M6 10h8M10 6v8" stroke="#ef4444" stroke-width="2" stroke-linecap="round"/><circle cx="10" cy="10" r="8" stroke="#ef4444" stroke-width="2"/></svg>
          </div>
          <div>
            <strong>Wrong word, wrong context</strong>
            <p>You know the word, but you use it in awkward or incorrect situations.</p>
          </div>
        </div>
        <div class="problem__point fade-in">
          <div class="problem__icon">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4 16l6-6 6 6M4 10l6-6 6 6" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <div>
            <strong>Can't use words naturally</strong>
            <p>You recognize vocabulary in reading but struggle to produce it in speech or writing.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- See It In Action — word / phrase / idiom depth -->
  <section class="section" id="see-it">
    <div class="container text-center">
      <span class="section__label">See It In Action</span>
      <h2>Real depth for every word, phrase, and idiom</h2>
      <p class="section__subtitle">
        Definitions in English plus your native language. Multiple meanings, real example sentences,
        and translation toggles you control per item.
      </p>
      <div class="shots-grid">
        <figure class="shot fade-in">
          <img src="/images/shot-word.png" alt="The Meanings card for the word 'ephemeral' showing two numbered definitions in English with Vietnamese translations underneath, plus six example sentences (three per meaning) with their own translation toggles." width="852" height="834" loading="lazy" />
          <figcaption>
            <strong>Words</strong>
            <span>Multiple meanings, IPA, examples — translated to your language.</span>
          </figcaption>
        </figure>
        <figure class="shot fade-in">
          <img src="/images/shot-phrase.png" alt="The Phrasal Verbs card for 'apply for' showing two distinct senses ('formal request' and 'request officially that a rule be granted') with Vietnamese translations and example sentences." width="852" height="734" loading="lazy" />
          <figcaption>
            <strong>Phrasal verbs</strong>
            <span>Each sense pulled out separately — no more guessing which one fits.</span>
          </figcaption>
        </figure>
        <figure class="shot fade-in">
          <img src="/images/shot-idiom.png" alt="The Common Idioms card for 'beat around the bush' showing the figurative meaning with Vietnamese translation and three example sentences in real contexts." width="852" height="405" loading="lazy" />
          <figcaption>
            <strong>Idioms</strong>
            <span>Figurative meaning explained, with sentences that show how natives actually use it.</span>
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- Features (Vocab Mine 2 design — Page 3: six cards in a 3x2 grid,
       each with a light-cyan icon tile, on a cream surface) -->
  <section class="features section--cream-alt" id="features">
    <div class="container text-center">
      <span class="section__eyebrow">FEATURES</span>
      <h2 class="section__title">Everything You Need to Learn</h2>
      <p class="section__lead">Comprehensive tools designed to make vocabulary acquisition natural and lasting.</p>
      <div class="features__grid">
        <div class="feat-card fade-in">
          <div class="feat-card__icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none"><path d="M12 3l1.6 4.2L18 8.8l-3.4 2.7 1.2 4.3L12 13.6 8.2 15.8l1.2-4.3L6 8.8l4.4-1.6L12 3z" stroke="#3b82f6" stroke-width="1.8" stroke-linejoin="round"/><path d="M5 19h9" stroke="#3b82f6" stroke-width="1.8" stroke-linecap="round"/></svg>
          </div>
          <h3>AI Definitions</h3>
          <p>Context-aware definitions generated instantly for any word, tailored to your proficiency level.</p>
        </div>
        <div class="feat-card fade-in">
          <div class="feat-card__icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none"><path d="M4 9v6h4l5 4V5L8 9H4z" stroke="#3b82f6" stroke-width="1.8" stroke-linejoin="round"/><path d="M16.5 8.5a5 5 0 010 7M19 6a8 8 0 010 12" stroke="#3b82f6" stroke-width="1.8" stroke-linecap="round"/></svg>
          </div>
          <h3>Pronunciation</h3>
          <p>IPA phonetics and audio pronunciation to ensure you learn how to say every word correctly.</p>
        </div>
        <div class="feat-card fade-in">
          <div class="feat-card__icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2v10z" stroke="#3b82f6" stroke-width="1.8" stroke-linejoin="round"/><path d="M7 8h10M7 12h6" stroke="#3b82f6" stroke-width="1.8" stroke-linecap="round"/></svg>
          </div>
          <h3>Examples</h3>
          <p>Multiple real-world usage examples showing how each word is naturally used in context.</p>
        </div>
        <div class="feat-card fade-in">
          <div class="feat-card__icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="#3b82f6" stroke-width="1.8"/><path d="M3 12h18M12 3a14 14 0 010 18M12 3a14 14 0 000 18" stroke="#3b82f6" stroke-width="1.8" stroke-linecap="round"/></svg>
          </div>
          <h3>Translations</h3>
          <p>Accurate translations into your native language to anchor meaning with familiar ground.</p>
        </div>
        <div class="feat-card fade-in">
          <div class="feat-card__icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none"><path d="M12 3l9 5-9 5-9-5 9-5z" stroke="#3b82f6" stroke-width="1.8" stroke-linejoin="round"/><path d="M3 13l9 5 9-5" stroke="#3b82f6" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3>Learning Packs</h3>
          <p>Pre-built and custom word collections organized by topic, difficulty or your personal goals.</p>
        </div>
        <div class="feat-card fade-in">
          <div class="feat-card__icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none"><path d="M3 7a2 2 0 012-2h4l2 2.5h8a2 2 0 012 2V17a2 2 0 01-2 2H5a2 2 0 01-2-2V7z" stroke="#3b82f6" stroke-width="1.8" stroke-linejoin="round"/></svg>
          </div>
          <h3>Collections</h3>
          <p>Organize words into personal collections - by project, book, conversation or any theme.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Five Learning Modes in practice -->
  <section class="section" id="learning-modes">
    <div class="container">
      <div class="text-center">
        <span class="section__label">Learning Modes</span>
        <h2>Five ways to master a word</h2>
        <p class="section__subtitle">
          Each pack type tests a different skill, taking you from recognising a word in the wild
          to producing it naturally in your own writing.
        </p>
      </div>
      <div class="modes-list">
        <article class="mode fade-in">
          <div class="mode__copy">
            <span class="mode__pill">1 / 5</span>
            <h3>Meaning Memorization</h3>
            <p>Type or pick the definition. Locks in what each word actually means before you start using it in context.</p>
          </div>
          <div class="mode__shot">
            <img src="/images/shot-learn-meaning.png" alt="A Meaning Memorization exercise asking 'What does this word mean?' for the word 'ephemeral' with its IPA pronunciation and a free-text response box." width="900" height="500" loading="lazy" />
          </div>
        </article>
        <article class="mode mode--flipped fade-in">
          <div class="mode__copy">
            <span class="mode__pill">2 / 5</span>
            <h3>Nuance Learning</h3>
            <p>Same context, three near-synonyms — pick the one that actually fits. This is where most learners get stuck and we go deep.</p>
          </div>
          <div class="mode__shot">
            <img src="/images/shot-learn-nuance.png" alt="A Nuance Learning exercise: 'The wildflowers that carpeted the meadow for a single week each spring are a classic example of ___ beauty.' with three options: ephemeral, transient, temporary." width="900" height="400" loading="lazy" />
          </div>
        </article>
        <article class="mode fade-in">
          <div class="mode__copy">
            <span class="mode__pill">3 / 5</span>
            <h3>Right Word Selection</h3>
            <p>A sentence with a blank, multiple plausible words. Tests whether you can tell apart words whose dictionary definitions look identical.</p>
          </div>
          <div class="mode__shot">
            <img src="/images/shot-learn-word-sel.png" alt="A Right Word Selection exercise: 'The street artist specialized in ___ installations that lasted only until the next rain.' with options ephemeral, transient, fleeting." width="900" height="450" loading="lazy" />
          </div>
        </article>
        <article class="mode mode--flipped fade-in">
          <div class="mode__copy">
            <span class="mode__pill">4 / 5</span>
            <h3>Right Sentence Selection</h3>
            <p>Given a word, choose the sentence that uses it naturally. The wrong options are designed to look right at first glance.</p>
          </div>
          <div class="mode__shot">
            <img src="/images/shot-learn-sent-sel.png" alt="A Right Sentence Selection exercise: 'Which sentence best demonstrates the use of ephemeral?' with three options A/B/C — only one is a natural use." width="900" height="600" loading="lazy" />
          </div>
        </article>
        <article class="mode fade-in">
          <div class="mode__copy">
            <span class="mode__pill">5 / 5</span>
            <h3>Writing Practice</h3>
            <p>Compose a short passage using the word in your own sentences. AI grades the result and gives feedback on usage, style, and accuracy.</p>
          </div>
          <div class="mode__shot">
            <img src="/images/shot-learn-writing.png" alt="A Writing Practice exercise prompting a 300-word descriptive paragraph using the word 'ephemeral', with a word counter showing minimum length requirements." width="900" height="600" loading="lazy" />
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- How It Works (Vocab Mine 2 design — Page 2: four numbered step cards
       with gradient badges and connector lines, on a cream surface) -->
  <section class="how section--cream" id="how-it-works">
    <div class="container text-center">
      <span class="section__eyebrow">HOW IT WORKS</span>
      <h2 class="section__title">Four Steps to Vocabulary Mastery</h2>
      <p class="section__lead">Our AI-powered approach makes learning new words efficient, engaging and effective.</p>
      <div class="how__steps">
        <div class="how-card fade-in">
          <div class="how-card__badge">1</div>
          <h3>Add a word</h3>
          <p>Type any English word you want to learn. Import from text or let AI suggest words based on your level.</p>
        </div>
        <div class="how-card fade-in">
          <div class="how-card__badge">2</div>
          <h3>AI Generates Content</h3>
          <p>Our AI instantly creates definitions, pronunciations, synonyms, translations and example sentences.</p>
        </div>
        <div class="how-card fade-in">
          <div class="how-card__badge">3</div>
          <h3>Practice</h3>
          <p>Reinforce learning through quizzes, flashcards and spaced repetition exercises tailored to you.</p>
        </div>
        <div class="how-card fade-in">
          <div class="how-card__badge">4</div>
          <h3>Master</h3>
          <p>Track progress, build streaks and watch your vocabulary grow measurably over time.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="section" id="stats">
    <div class="container text-center">
      <span class="section__label">By the Numbers</span>
      <h2>Built for Serious Learners</h2>
      <div class="stats__grid">
        <div class="stat fade-in">
          <div class="stat__number">5</div>
          <div class="stat__label">Learning Modes</div>
        </div>
        <div class="stat fade-in">
          <div class="stat__number">80+</div>
          <div class="stat__label">Native Languages</div>
        </div>
        <div class="stat fade-in">
          <div class="stat__number">6</div>
          <div class="stat__label">Mastery Levels</div>
        </div>
        <div class="stat fade-in">
          <div class="stat__number">AI</div>
          <div class="stat__label">Powered Processing</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Teaser -->
  <section class="section section--alt" id="pricing">
    <div class="container text-center">
      <span class="section__label">Pricing</span>
      <h2>Start Free, Upgrade Anytime</h2>
      <p class="section__subtitle">Three plans designed to grow with you. Cancel anytime.</p>
      <div class="pricing-teaser__cards">
        <div class="pricing-teaser__card fade-in">
          <h3>Free</h3>
          <ul>
            <li>15 words per month</li>
            <li>5 learning packs per month</li>
            <li>All 5 learning modes</li>
          </ul>
        </div>
        <div class="pricing-teaser__card pricing-teaser__card--pro fade-in">
          <h3>Pro &mdash; $4.99/mo</h3>
          <ul>
            <li>300 words per month</li>
            <li>Unlimited learning packs</li>
            <li>Community sharing &amp; cloning</li>
          </ul>
        </div>
        <div class="pricing-teaser__card pricing-teaser__card--premium fade-in">
          <h3>Premium &mdash; $9.99/mo</h3>
          <ul>
            <li>1,000 words per month</li>
            <li>Priority processing queue</li>
            <li>Advanced learning analytics</li>
          </ul>
        </div>
      </div>
      <a href="/pricing/" class="btn btn--secondary" data-ga-cta="see_full_pricing" data-ga-location="pricing_teaser">See Full Pricing</a>
    </div>
  </section>

  <FinalCta />
</BaseLayout>
