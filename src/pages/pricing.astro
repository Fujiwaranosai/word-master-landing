---
import BaseLayout from '../layouts/BaseLayout.astro';
import FinalCta from '../components/FinalCta.astro';
import {
  SITE_NAME,
  APP_REGISTER_URL,
  APP_REGISTER_PRO_URL,
  APP_REGISTER_PREMIUM_URL,
} from '../consts';
---

<BaseLayout
  title={`Pricing — ${SITE_NAME}`}
  description={`Simple, transparent pricing for ${SITE_NAME}. Start free, upgrade to Pro or Premium when you're ready.`}
  ogTitle={`Pricing — ${SITE_NAME}`}
  ogDescription="Simple, transparent pricing. Start free, upgrade to Pro or Premium when you're ready."
  twitterCard="summary"
  canonicalPath="/pricing/"
  currentPage="pricing"
>
  <!-- Pricing Hero -->
  <section class="pricing-hero">
    <div class="container">
      <h1>Simple, Transparent Pricing</h1>
      <p>Start free. Upgrade when you're ready.</p>
    </div>
  </section>

  <!-- Pricing Cards -->
  <section class="section">
    <div class="container">
      <!-- Monthly / Annual toggle -->
      <div class="billing-toggle__wrap">
        <div class="billing-toggle" role="group" aria-label="Billing period">
          <button
            type="button"
            class="billing-toggle__btn"
            id="billingToggleMonthly"
            aria-pressed="true"
            data-period="monthly"
          >
            Monthly
          </button>
          <button
            type="button"
            class="billing-toggle__btn"
            id="billingToggleAnnual"
            aria-pressed="false"
            data-period="annual"
          >
            Annual
            <span class="billing-toggle__save">2 months free</span>
          </button>
        </div>
      </div>
      <p class="billing-toggle__hint" id="billingToggleHint">Billed monthly. Cancel anytime.</p>

      <div class="pricing-cards">
        <!-- Free Plan -->
        <div class="pricing-card fade-in">
          <h3>Free</h3>
          <div class="pricing-card__price">
            <span class="pricing-card__amount">$0</span>
            <span class="pricing-card__period"> / forever</span>
            <span class="pricing-card__price-line">No credit card required</span>
          </div>
          <ul class="pricing-card__features">
            <li>15 words per month</li>
            <li>5 learning packs per month</li>
            <li>All 5 learning modes</li>
            <li>Unlimited collections</li>
            <li>Browse community collections</li>
            <li>Full AI word processing</li>
            <li class="disabled">Community sharing &amp; cloning</li>
            <li class="disabled">Priority support</li>
          </ul>
          <a href={APP_REGISTER_URL} class="btn btn--secondary" data-ga-cta="get_started_free" data-ga-location="pricing_card_free">Get Started</a>
        </div>

        <!-- Pro Plan -->
        <div class="pricing-card pricing-card--featured fade-in">
          <span class="pricing-card__badge">Recommended</span>
          <h3>Pro</h3>
          <div class="pricing-card__price">
            <div class="pricing-card__price--monthly">
              <span class="pricing-card__amount">$4.99</span>
              <span class="pricing-card__period"> / month</span>
              <span class="pricing-card__price-line">Billed monthly</span>
            </div>
            <div class="pricing-card__price--annual">
              <span class="pricing-card__amount">$49.99</span>
              <span class="pricing-card__period"> / year</span>
              <span class="pricing-card__price-line">
                ≈ $4.17/mo
                <span class="pricing-card__save-pill">Save $9.89</span>
              </span>
            </div>
          </div>
          <ul class="pricing-card__features">
            <li>Everything in Free</li>
            <li>300 words per month</li>
            <li>Unlimited learning packs</li>
            <li>Community sharing &amp; cloning</li>
            <li>Full mastery tracking with analytics</li>
            <li>Priority email support</li>
          </ul>
          <a href={APP_REGISTER_PRO_URL} class="btn btn--primary" data-ga-cta="start_pro" data-ga-location="pricing_card_pro">Start Pro</a>
        </div>

        <!-- Premium Plan -->
        <div class="pricing-card pricing-card--premium fade-in">
          <span class="pricing-card__caption">Best for power users</span>
          <h3>Premium</h3>
          <div class="pricing-card__price">
            <div class="pricing-card__price--monthly">
              <span class="pricing-card__amount">$9.99</span>
              <span class="pricing-card__period"> / month</span>
              <span class="pricing-card__price-line">Billed monthly</span>
            </div>
            <div class="pricing-card__price--annual">
              <span class="pricing-card__amount">$99.99</span>
              <span class="pricing-card__period"> / year</span>
              <span class="pricing-card__price-line">
                ≈ $8.33/mo
                <span class="pricing-card__save-pill">Save $19.89</span>
              </span>
            </div>
          </div>
          <ul class="pricing-card__features">
            <li>Everything in Pro</li>
            <li>1,000 words per month</li>
            <li>Priority processing queue</li>
            <li>Advanced learning analytics</li>
            <li>Best for power learners</li>
          </ul>
          <a href={APP_REGISTER_PREMIUM_URL} class="btn btn--primary" data-ga-cta="start_premium" data-ga-location="pricing_card_premium">Start Premium</a>
        </div>
      </div>

      <!-- FAQ -->
      <div class="faq">
        <h2 class="text-center" style="margin-bottom: 8px;">Frequently Asked Questions</h2>
        <div class="faq__item fade-in">
          <div class="faq__question">Can I cancel anytime?</div>
          <div class="faq__answer">Yes, absolutely. There are no contracts or commitments. You can cancel your Pro or Premium subscription at any time, and you'll continue to have access until the end of your billing period.</div>
        </div>
        <div class="faq__item fade-in">
          <div class="faq__question">What's the difference between Pro and Premium?</div>
          <div class="faq__answer">Pro is built for steady learners — 300 new words per month, unlimited learning packs, community sharing &amp; cloning, and full mastery analytics. Premium is for power learners who want to add words at scale: 1,000 words per month, priority processing queue, and advanced analytics. Everything in Pro is included in Premium.</div>
        </div>
        <div class="faq__item fade-in">
          <div class="faq__question">What happens to my words if I downgrade?</div>
          <div class="faq__answer">You keep all your words and their processed data. You simply won't be able to add more than your new plan's limit (15 words/month and 5 learning packs/month on Free) or use community sharing &amp; cloning until you upgrade again. All 5 learning modes remain available on every plan.</div>
        </div>
        <div class="faq__item fade-in">
          <div class="faq__question">Is my data safe?</div>
          <div class="faq__answer">Yes. Your data is stored securely on AWS infrastructure with encryption. See our <a href="/privacy/">Privacy Policy</a> for full details on how we handle your information.</div>
        </div>
        <div class="faq__item fade-in">
          <div class="faq__question">What languages are supported?</div>
          <div class="faq__answer">{SITE_NAME} is designed for English vocabulary learning. All content (definitions, examples, nuances) can be translated to 50+ native languages so you can learn in the way that's most effective for you.</div>
        </div>
        <div class="faq__item fade-in">
          <div class="faq__question">Can I use it on mobile?</div>
          <div class="faq__answer">Yes! {SITE_NAME} is a Progressive Web App (PWA), which means it works great on any device with a modern browser. You can add it to your home screen for an app-like experience.</div>
        </div>
      </div>
    </div>
  </section>

  <FinalCta />

  <script is:inline>
    (function () {
      var monthlyBtn = document.getElementById('billingToggleMonthly');
      var annualBtn = document.getElementById('billingToggleAnnual');
      var hint = document.getElementById('billingToggleHint');
      if (!monthlyBtn || !annualBtn) return;

      function setPeriod(period) {
        var isAnnual = period === 'annual';
        document.body.classList.toggle('is-annual', isAnnual);
        monthlyBtn.setAttribute('aria-pressed', String(!isAnnual));
        annualBtn.setAttribute('aria-pressed', String(isAnnual));
        if (hint) {
          hint.textContent = isAnnual
            ? 'Billed once per year. Save ~17% vs monthly.'
            : 'Billed monthly. Cancel anytime.';
        }
      }

      monthlyBtn.addEventListener('click', function () { setPeriod('monthly'); });
      annualBtn.addEventListener('click', function () { setPeriod('annual'); });
    })();
  </script>
</BaseLayout>
