---
/**
 * Canonical "latest" Privacy Policy page at /privacy — the URL the web app,
 * admin, and SEO/canonical all depend on. It renders whichever version is
 * marked `current` in the registry, so bumping `privacy.current` automatically
 * re-points this page to the new version component (no edits here needed).
 *
 * Permanent per-version URLs live at /privacy/<version> (see privacy/[version].astro).
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_NAME } from '../consts';
import { CURRENT_PRIVACY_VERSION } from '../legal';

// Eagerly load every published Privacy version component; pick the current one.
const versionComponents = import.meta.glob<{ default: any }>(
  '../components/legal/privacy/*.astro',
  { eager: true },
);
const currentEntry = Object.entries(versionComponents).find(
  ([path]) => path.endsWith(`/${CURRENT_PRIVACY_VERSION}.astro`),
);
if (!currentEntry) {
  throw new Error(
    `No Privacy component found for current version "${CURRENT_PRIVACY_VERSION}". ` +
      `Expected src/components/legal/privacy/${CURRENT_PRIVACY_VERSION}.astro`,
  );
}
const CurrentPrivacy = currentEntry[1].default;
---

<BaseLayout
  title={`Privacy Policy — ${SITE_NAME}`}
  description={`Privacy Policy for ${SITE_NAME} vocabulary learning application. Learn how we collect, use, and protect your data.`}
  canonicalPath="/privacy/"
  currentPage="privacy"
>
  <CurrentPrivacy />
</BaseLayout>
