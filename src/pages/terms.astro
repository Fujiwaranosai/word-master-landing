---
/**
 * Canonical "latest" Terms of Service page at /terms — the URL the web app,
 * admin, and SEO/canonical all depend on. It renders whichever version is
 * marked `current` in the registry, so bumping `terms.current` automatically
 * re-points this page to the new version component (no edits here needed).
 *
 * Permanent per-version URLs live at /terms/<version> (see terms/[version].astro).
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_NAME } from '../consts';
import { CURRENT_TERMS_VERSION } from '../legal';

// Eagerly load every published Terms version component; pick the current one.
const versionComponents = import.meta.glob<{ default: any }>(
  '../components/legal/terms/*.astro',
  { eager: true },
);
const currentEntry = Object.entries(versionComponents).find(
  ([path]) => path.endsWith(`/${CURRENT_TERMS_VERSION}.astro`),
);
if (!currentEntry) {
  throw new Error(
    `No Terms component found for current version "${CURRENT_TERMS_VERSION}". ` +
      `Expected src/components/legal/terms/${CURRENT_TERMS_VERSION}.astro`,
  );
}
const CurrentTerms = currentEntry[1].default;
---

<BaseLayout
  title={`Terms of Service — ${SITE_NAME}`}
  description={`Terms of Service for ${SITE_NAME} vocabulary learning application.`}
  canonicalPath="/terms/"
  currentPage="terms"
>
  <CurrentTerms />
</BaseLayout>
